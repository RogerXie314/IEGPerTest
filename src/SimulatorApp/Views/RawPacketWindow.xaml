<Window x:Class="SimulatorApp.Views.RawPacketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="攻击报文发送" Height="680" Width="980"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="CanResize">
  <Window.Resources>
    <!-- 分组标题样式 -->
    <Style x:Key="GroupHeader" TargetType="TextBlock">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#1A1A2E"/>
      <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>
    <!-- 标签样式 -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="#555"/>
      <Setter Property="Margin" Value="0,4,0,1"/>
    </Style>
    <!-- 步骤序号样式 -->
    <Style x:Key="StepBadge" TargetType="Border">
      <Setter Property="Background" Value="#4A90E2"/>
      <Setter Property="CornerRadius" Value="9"/>
      <Setter Property="Width" Value="18"/>
      <Setter Property="Height" Value="18"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- 顶部工具栏 -->
      <RowDefinition Height="*"/>     <!-- 主内容区 -->
    </Grid.RowDefinitions>

    <!-- ══ 顶部工具栏：网卡 + 状态 ══ -->
    <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,7">
      <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
          <TextBlock Text="网卡" VerticalAlignment="Center" FontSize="12" Foreground="#555" Margin="0,0,6,0"/>
          <ComboBox Width="340" ItemsSource="{Binding Adapters}"
                    SelectedItem="{Binding SelectedAdapter}"
                    DisplayMemberPath="DisplayText" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
          <TextBlock Text="Npcap：" VerticalAlignment="Center" FontSize="11" Foreground="#777"/>
          <TextBlock Text="{Binding NpcapStatusText}" VerticalAlignment="Center" FontSize="11" Foreground="#1565C0" FontWeight="SemiBold"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ══ 主内容区：左侧配置 + 右侧工作区 ══ -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="270" MinWidth="240"/>  <!-- 左侧配置区 -->
        <ColumnDefinition Width="*"/>                   <!-- 右侧工作区 -->
      </Grid.ColumnDefinitions>

      <!-- ══ 左侧配置区（操作流程从上到下） ══ -->
      <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="12,10">

            <!-- STEP 1：选择攻击报文 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <Border Style="{StaticResource StepBadge}">
                <TextBlock Text="1" Foreground="White" FontSize="10" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="选择攻击报文" Style="{StaticResource GroupHeader}" VerticalAlignment="Center"/>
            </StackPanel>
            <ItemsControl ItemsSource="{Binding BuiltinPackets}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayText}"
                            Margin="0,3" FontSize="12"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="或点击右侧「导入报文」加载自定义报文" FontSize="10"
                       Foreground="#999" Margin="0,4,0,0" TextWrapping="Wrap"/>

            <Separator Margin="0,10"/>

            <!-- STEP 2：设置目标 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <Border Style="{StaticResource StepBadge}">
                <TextBlock Text="2" Foreground="White" FontSize="10" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="设置目标" Style="{StaticResource GroupHeader}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="目的 IP" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding DestIp, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="{Binding DestIpError}" Foreground="#E53935" FontSize="10"/>
            <TextBlock Text="目的 MAC" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding DestMac, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="{Binding DestMacError}" Foreground="#E53935" FontSize="10"/>

            <Separator Margin="0,10"/>

            <!-- STEP 3：源IP变化（可选） -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <Border Style="{StaticResource StepBadge}" Background="#9E9E9E">
                <TextBlock Text="3" Foreground="White" FontSize="10" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <CheckBox IsChecked="{Binding SrcIpRuleEnabled}" VerticalAlignment="Center"
                        FontWeight="SemiBold" FontSize="12" Content="源IP自动递增（可选）"/>
            </StackPanel>
            <Grid IsEnabled="{Binding SrcIpRuleEnabled}" Margin="0,0,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Row="0" Grid.Column="0" Text="起始值" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
              <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding SrcIpStart, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,1"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="最大值" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
              <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding SrcIpMax, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,1"/>
              <TextBlock Grid.Row="2" Grid.Column="0" Text="步长" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
              <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding SrcIpStep, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,1"/>
              <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                         Text="{Binding SrcIpRuleError}" Foreground="#E53935" FontSize="10" TextWrapping="Wrap"/>
            </Grid>

            <Separator Margin="0,10"/>

            <!-- STEP 4：发包配置 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <Border Style="{StaticResource StepBadge}">
                <TextBlock Text="4" Foreground="White" FontSize="10" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="发包配置" Style="{StaticResource GroupHeader}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 速率 -->
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <ComboBox Grid.Column="0" SelectedIndex="{Binding SpeedModeIndex}">
                <ComboBoxItem Content="包率 (PPS)"/>
                <ComboBoxItem Content="间隔 (μs)"/>
                <ComboBoxItem Content="最大速率"/>
              </ComboBox>
              <TextBox Grid.Column="1" Text="{Binding SpeedValue, UpdateSourceTrigger=PropertyChanged}"
                       Width="70" Margin="4,0,0,0" Visibility="{Binding SpeedValueVisible}"
                       VerticalAlignment="Center"/>
              <TextBlock Grid.Column="2" Text="{Binding SpeedValueUnit}" VerticalAlignment="Center"
                         Margin="3,0,0,0" Visibility="{Binding SpeedValueVisible}" FontSize="11" Foreground="#555"/>
            </Grid>
            <TextBlock Text="{Binding RateError}" Foreground="#E53935" FontSize="10"/>

            <!-- 发包模式 -->
            <Grid Margin="0,4,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <ComboBox Grid.Column="0" SelectedIndex="{Binding SendModeIndex}">
                <ComboBoxItem Content="持续发送"/>
                <ComboBoxItem Content="定量发送"/>
              </ComboBox>
              <TextBox Grid.Column="1" Text="{Binding BurstCount, UpdateSourceTrigger=PropertyChanged}"
                       Width="60" Margin="4,0,0,0" Visibility="{Binding BurstCountVisible}"
                       VerticalAlignment="Center"/>
              <TextBlock Grid.Column="2" Text="包" VerticalAlignment="Center" Margin="3,0,0,0"
                         Visibility="{Binding BurstCountVisible}" FontSize="11" Foreground="#555"/>
            </Grid>
            <TextBlock FontSize="10" Foreground="#999" TextWrapping="Wrap" Margin="0,3,0,0">
              持续：手动停止；定量：发完自动停止。
            </TextBlock>

            <Separator Margin="0,10"/>

            <!-- STEP 5：执行 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <Border Style="{StaticResource StepBadge}">
                <TextBlock Text="5" Foreground="White" FontSize="10" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="执行" Style="{StaticResource GroupHeader}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="▶  开始发送" Command="{Binding StartCommand}"
                    Background="#388E3C" Foreground="White" BorderThickness="0"
                    Height="38" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Button Content="■  停止" Command="{Binding StopCommand}"
                    Background="#C62828" Foreground="White" BorderThickness="0"
                    Height="34" FontSize="12" FontWeight="SemiBold"/>
            <Border Margin="0,8,0,0" Background="#F5F5F5" CornerRadius="4" Padding="8,6">
              <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"
                         FontSize="12" Foreground="#333" FontWeight="SemiBold"/>
            </Border>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ══ 右侧工作区：Stream 列表 + 统计 ══ -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" MinHeight="100"/>   <!-- Stream 列表，弹性 -->
          <RowDefinition Height="Auto"/>                <!-- 操作按钮 -->
          <RowDefinition Height="Auto"/>                <!-- 统计说明 -->
          <RowDefinition Height="Auto"/>                <!-- 统计表格 -->
        </Grid.RowDefinitions>

        <!-- Stream 列表 -->
        <DataGrid Grid.Row="0" ItemsSource="{Binding Streams}"
                  SelectedItem="{Binding SelectedStream}"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" FontSize="12"
                  BorderThickness="0" Margin="0">
          <DataGrid.Columns>
            <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="36"/>
            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="100"/>
            <DataGridTextColumn Header="源地址" Binding="{Binding SrcIp}" Width="105"/>
            <DataGridTextColumn Header="目的地址" Binding="{Binding DstIp}" Width="105"/>
            <DataGridTextColumn Header="协议" Binding="{Binding Type}" Width="65"/>
            <DataGridTextColumn Header="长度(B)" Binding="{Binding FrameLen}" Width="60"/>
            <DataGridTextColumn Header="信息" Binding="{Binding Info}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>

        <!-- 操作按钮行 -->
        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,1" Padding="8,5">
          <StackPanel Orientation="Horizontal">
            <Button Content="导入报文" Command="{Binding ImportCommand}" Padding="10,4" Margin="0,0,6,0"/>
            <Button Content="编辑字段" Command="{Binding EditStreamCommand}" Padding="10,4" Margin="0,0,6,0"/>
            <Button Content="删除" Command="{Binding DeleteStreamCommand}" Padding="10,4" Margin="0,0,6,0"/>
            <Button Content="清空全部" Command="{Binding ClearStreamsCommand}" Padding="10,4"
                    Background="#EF5350" Foreground="White" BorderThickness="0"/>
          </StackPanel>
        </Border>

        <!-- 统计说明 -->
        <Border Grid.Row="2" Background="#E8F0FE" BorderBrush="#BBDEFB" BorderThickness="0,0,0,1" Padding="10,5">
          <TextBlock FontSize="11" Foreground="#1565C0" TextWrapping="Wrap">
            <Run FontWeight="Bold">实时 bps/pps</Run><Run> = 最近1秒均值；</Run>
            <Run FontWeight="Bold">平均 bps/pps</Run><Run> = 本次启动以来总均值。</Run>
            <Run Foreground="#555">  bps = 每秒比特数（带宽）；pps = 每秒包数（速率）。</Run>
          </TextBlock>
        </Border>

        <!-- 统计表格 -->
        <Border Grid.Row="3" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="72"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="90"/>
              <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="28"/>  <!-- 表头 -->
              <RowDefinition Height="30"/>  <!-- 发送行 -->
              <RowDefinition Height="28"/>  <!-- 失败行 -->
            </Grid.RowDefinitions>

            <!-- 表头 -->
            <Border Grid.Row="0" Grid.Column="0" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"/>
            <Border Grid.Row="0" Grid.Column="1" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="实时 bps" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="#546E7A"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="实时 pps" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="#546E7A"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="3" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="平均 bps" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="#546E7A"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="4" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="平均 pps" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="#546E7A"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="5" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="报文总数" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="#546E7A"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="6" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,0,1">
              <TextBlock Text="总流量 (B)" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="#546E7A"/>
            </Border>

            <!-- 发送行 -->
            <Border Grid.Row="1" Grid.Column="0" Background="#F9FBE7" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="发送" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#33691E"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.CurrentBps, StringFormat=F0}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,0" FontSize="13" FontWeight="SemiBold"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="2" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.CurrentPps, StringFormat=F1}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,0" FontSize="13" FontWeight="SemiBold"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="3" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.AvgBps, StringFormat=F0}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,0" FontSize="12" Foreground="#555"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="4" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.AvgPps, StringFormat=F1}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,0" FontSize="12" Foreground="#555"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="5" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.SendTotal}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,0" FontSize="12"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="6" BorderBrush="#CFD8DC" BorderThickness="0,0,0,1">
              <TextBlock Text="{Binding Stats.SendBytes}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,0" FontSize="12"/>
            </Border>

            <!-- 失败行 -->
            <Border Grid.Row="2" Grid.Column="0" Background="#FFF8F8" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0">
              <TextBlock Text="失败" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="#B71C1C"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0"/>
            <Border Grid.Row="2" Grid.Column="2" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0"/>
            <Border Grid.Row="2" Grid.Column="3" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0"/>
            <Border Grid.Row="2" Grid.Column="4" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0"/>
            <Border Grid.Row="2" Grid.Column="5" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0">
              <TextBlock Text="{Binding Stats.SendFail}" HorizontalAlignment="Right" VerticalAlignment="Center"
                         Padding="8,0" FontSize="12" Foreground="#C62828" FontWeight="SemiBold"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="6"/>
          </Grid>
        </Border>

      </Grid>
    </Grid>
  </Grid>
</Window>
