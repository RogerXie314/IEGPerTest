<Window x:Class="SimulatorApp.Views.RawPacketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="攻击报文发送" Height="660" Width="1050"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- 顶部：网卡选择 + Npcap 状态 -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
      <Label Content="网卡：" VerticalAlignment="Center"/>
      <ComboBox Width="380" ItemsSource="{Binding Adapters}"
                SelectedItem="{Binding SelectedAdapter}"
                DisplayMemberPath="DisplayText" VerticalAlignment="Center"/>
      <Label Content="Npcap：" Margin="16,0,0,0" VerticalAlignment="Center"/>
      <TextBlock Text="{Binding NpcapStatusText}" VerticalAlignment="Center" Foreground="#1565C0"/>
    </StackPanel>

    <!-- 主区域：左/中/右 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="210"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="210"/>
      </Grid.ColumnDefinitions>

      <!-- ══ 左侧 ══ -->
      <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="8,6">
            <TextBlock Text="内置攻击报文" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ItemsControl ItemsSource="{Binding BuiltinPackets}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayText}" Margin="0,2"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Separator Margin="0,8"/>
            <TextBlock Text="目的地址" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="目的 IP：" FontSize="11" Foreground="#555"/>
            <TextBox Text="{Binding DestIp, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
            <TextBlock Text="{Binding DestIpError}" Foreground="Red" FontSize="10"/>
            <TextBlock Text="目的 MAC：" FontSize="11" Foreground="#555" Margin="0,4,0,0"/>
            <TextBox Text="{Binding DestMac, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
            <TextBlock Text="{Binding DestMacError}" Foreground="Red" FontSize="10"/>

            <Separator Margin="0,8"/>
            <CheckBox IsChecked="{Binding SrcIpRuleEnabled}" Content="启用源IP变化规则"
                      FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Grid IsEnabled="{Binding SrcIpRuleEnabled}">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Row="0" Grid.Column="0" Text="起始值" VerticalAlignment="Center" FontSize="11"/>
              <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding SrcIpStart, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="最大不超过" VerticalAlignment="Center" FontSize="11" TextWrapping="Wrap"/>
              <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding SrcIpMax, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
              <TextBlock Grid.Row="2" Grid.Column="0" Text="步长" VerticalAlignment="Center" FontSize="11"/>
              <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding SrcIpStep, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
              <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                         Text="{Binding SrcIpRuleError}" Foreground="Red" FontSize="10" TextWrapping="Wrap"/>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ══ 中部：Stream 列表（固定高度）+ 统计面板（占剩余空间） ══ -->
      <Grid Grid.Column="1" Margin="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="120"/>   <!-- Stream 列表，固定高度约减半 -->
          <RowDefinition Height="Auto"/>  <!-- 操作按钮 -->
          <RowDefinition Height="*"/>     <!-- 统计面板，占剩余全部空间 -->
        </Grid.RowDefinitions>

        <!-- Stream 列表 -->
        <DataGrid Grid.Row="0" ItemsSource="{Binding Streams}"
                  SelectedItem="{Binding SelectedStream}"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" FontSize="12">
          <DataGrid.Columns>
            <DataGridTextColumn Header="索引" Binding="{Binding Id}" Width="45"/>
            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="110"/>
            <DataGridTextColumn Header="源地址" Binding="{Binding SrcIp}" Width="110"/>
            <DataGridTextColumn Header="目的地址" Binding="{Binding DstIp}" Width="110"/>
            <DataGridTextColumn Header="协议" Binding="{Binding Type}" Width="70"/>
            <DataGridTextColumn Header="长度(B)" Binding="{Binding FrameLen}" Width="60"/>
            <DataGridTextColumn Header="信息" Binding="{Binding Info}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4">
          <Button Content="导入报文" Command="{Binding ImportCommand}" Width="80" Margin="0,0,4,0"/>
          <Button Content="编辑字段" Command="{Binding EditStreamCommand}" Width="80" Margin="0,0,4,0"/>
          <Button Content="删除" Command="{Binding DeleteStreamCommand}" Width="60" Margin="0,0,4,0"/>
          <Button Content="清空" Command="{Binding ClearStreamsCommand}" Width="60"/>
        </StackPanel>

        <!-- 统计面板（占剩余空间） -->
        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1" Margin="0,4,0,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>  <!-- 说明行 -->
              <RowDefinition Height="Auto"/>  <!-- 表头 -->
              <RowDefinition Height="Auto"/>  <!-- 发送行 -->
              <RowDefinition Height="Auto"/>  <!-- 失败行 -->
              <RowDefinition Height="*"/>     <!-- 填充 -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="70"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 说明行 -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="7"
                    Background="#EEF4FF" BorderBrush="#CCC" BorderThickness="0,0,0,1" Padding="6,3">
              <TextBlock FontSize="11" Foreground="#444" TextWrapping="Wrap">
                <Run FontWeight="SemiBold">bps</Run><Run>（bits per second）= 每秒传输比特数，反映带宽占用；</Run>
                <Run FontWeight="SemiBold">pps</Run><Run>（packets per second）= 每秒发包数，反映发包速率。</Run>
                <Run Foreground="#888">实时 = 最近1秒均值；平均 = 启动以来总均值。</Run>
              </TextBlock>
            </Border>

            <!-- 表头 -->
            <Border Grid.Row="1" Grid.Column="0" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,0,1,1"/>
            <Border Grid.Row="1" Grid.Column="1" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="实时 bps" HorizontalAlignment="Center" FontSize="11" Padding="2"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="2" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="实时 pps" HorizontalAlignment="Center" FontSize="11" Padding="2"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="3" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="平均 bps" HorizontalAlignment="Center" FontSize="11" Padding="2"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="4" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="平均 pps" HorizontalAlignment="Center" FontSize="11" Padding="2"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="5" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="报文总数" HorizontalAlignment="Center" FontSize="11" Padding="2"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="6" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,0,0,1">
              <TextBlock Text="总流量 (B)" HorizontalAlignment="Center" FontSize="11" Padding="2"/>
            </Border>

            <!-- 发送行 -->
            <Border Grid.Row="2" Grid.Column="0" BorderBrush="#CCC" BorderThickness="0,0,1,1" Background="#FAFAFA">
              <TextBlock Text="发送" HorizontalAlignment="Center" FontSize="12" Padding="2" FontWeight="SemiBold"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="1" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.CurrentBps, StringFormat=F0}" HorizontalAlignment="Right" Padding="6,3" FontSize="12"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="2" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.CurrentPps, StringFormat=F1}" HorizontalAlignment="Right" Padding="6,3" FontSize="12"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="3" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.AvgBps, StringFormat=F0}" HorizontalAlignment="Right" Padding="6,3" FontSize="12"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="4" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.AvgPps, StringFormat=F1}" HorizontalAlignment="Right" Padding="6,3" FontSize="12"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="5" BorderBrush="#CCC" BorderThickness="0,0,1,1">
              <TextBlock Text="{Binding Stats.SendTotal}" HorizontalAlignment="Right" Padding="6,3" FontSize="12"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="6" BorderBrush="#CCC" BorderThickness="0,0,0,1">
              <TextBlock Text="{Binding Stats.SendBytes}" HorizontalAlignment="Right" Padding="6,3" FontSize="12"/>
            </Border>

            <!-- 失败行 -->
            <Border Grid.Row="3" Grid.Column="0" BorderBrush="#CCC" BorderThickness="0,0,1,0" Background="#FAFAFA">
              <TextBlock Text="发送失败" HorizontalAlignment="Center" FontSize="12" Padding="2" FontWeight="SemiBold"/>
            </Border>
            <Border Grid.Row="3" Grid.Column="1" BorderBrush="#CCC" BorderThickness="0,0,1,0"/>
            <Border Grid.Row="3" Grid.Column="2" BorderBrush="#CCC" BorderThickness="0,0,1,0"/>
            <Border Grid.Row="3" Grid.Column="3" BorderBrush="#CCC" BorderThickness="0,0,1,0"/>
            <Border Grid.Row="3" Grid.Column="4" BorderBrush="#CCC" BorderThickness="0,0,1,0"/>
            <Border Grid.Row="3" Grid.Column="5" BorderBrush="#CCC" BorderThickness="0,0,1,0">
              <TextBlock Text="{Binding Stats.SendFail}" HorizontalAlignment="Right" Padding="6,3" FontSize="12"
                         Foreground="Red"/>
            </Border>
            <Border Grid.Row="3" Grid.Column="6"/>

            <!-- 填充区域（空白） -->
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="7" Background="White"/>
          </Grid>
        </Border>
      </Grid>

      <!-- ══ 右侧：速率配置 + 控制按钮 ══ -->
      <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1,0,0,0">
        <StackPanel Margin="8,6">
          <TextBlock Text="速率配置" FontWeight="SemiBold" Margin="0,0,0,6"/>
          <ComboBox SelectedIndex="{Binding SpeedModeIndex}" Margin="0,0,0,4">
            <ComboBoxItem Content="包率模式 (PPS)"/>
            <ComboBoxItem Content="间隔模式 (μs)"/>
            <ComboBoxItem Content="最大速率"/>
          </ComboBox>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,2" Visibility="{Binding SpeedValueVisible}">
            <TextBox Text="{Binding SpeedValue, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
            <TextBlock Text="{Binding SpeedValueUnit}" VerticalAlignment="Center" Margin="4,0,0,0"/>
          </StackPanel>
          <TextBlock Text="{Binding RateError}" Foreground="Red" FontSize="10"/>

          <Separator Margin="0,8"/>
          <TextBlock Text="发包模式" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <TextBlock FontSize="10" Foreground="#777" TextWrapping="Wrap" Margin="0,0,0,4">
            持续：一直发直到手动停止。&#x0a;定量：发完指定包数后自动停止。
          </TextBlock>
          <ComboBox SelectedIndex="{Binding SendModeIndex}" Margin="0,0,0,4">
            <ComboBoxItem Content="持续发送"/>
            <ComboBoxItem Content="定量发送"/>
          </ComboBox>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Visibility="{Binding BurstCountVisible}">
            <TextBox Text="{Binding BurstCount, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
            <TextBlock Text="包" VerticalAlignment="Center" Margin="4,0,0,0"/>
          </StackPanel>

          <Separator Margin="0,8"/>
          <Button Content="▶ 开始发送" Command="{Binding StartCommand}"
                  Background="#FF4CAF50" Foreground="White"
                  Height="36" Margin="0,4" FontSize="13" FontWeight="SemiBold"/>
          <Button Content="■ 停止" Command="{Binding StopCommand}"
                  Background="#FFF44336" Foreground="White"
                  Height="36" Margin="0,4" FontSize="13" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding StatusText}" Margin="0,6" TextWrapping="Wrap"
                     FontSize="11" Foreground="#555"/>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
