<Window x:Class="SimulatorApp.Views.RawPacketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="攻击报文发送" Height="660" Width="960"
        MinHeight="520" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="CanResize">
  <Window.Resources>
    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#37474F"/>
      <Setter Property="Margin" Value="0,8,0,3"/>
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="#607D8B"/>
      <Setter Property="Margin" Value="0,5,0,1"/>
    </Style>
    <Style x:Key="CompactInput" TargetType="TextBox">
      <Setter Property="MaxWidth" Value="160"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Padding" Value="4,3"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style x:Key="StepNum" TargetType="Border">
      <Setter Property="Background" Value="#1565C0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="Margin" Value="0,0,5,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="StepNumGray" TargetType="Border" BasedOn="{StaticResource StepNum}">
      <Setter Property="Background" Value="#90A4AE"/>
    </Style>
    <!-- 统计数字大字体 -->
    <Style x:Key="StatBig" TargetType="TextBlock">
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="8,0"/>
    </Style>
    <Style x:Key="StatSmall" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="8,0"/>
      <Setter Property="Foreground" Value="#546E7A"/>
    </Style>
    <Style x:Key="StatHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Foreground" Value="#546E7A"/>
    </Style>
  </Window.Resources>

  <!-- 整体：顶部工具栏 + 下方主区域 -->
  <DockPanel>

    <!-- ── 顶部工具栏 ── -->
    <Border DockPanel.Dock="Top" Background="#ECEFF1" BorderBrush="#CFD8DC"
            BorderThickness="0,0,0,1" Padding="10,6">
      <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
          <TextBlock Text="网卡" VerticalAlignment="Center" FontSize="11" Foreground="#546E7A" Margin="0,0,6,0"/>
          <ComboBox Width="320" ItemsSource="{Binding Adapters}"
                    SelectedItem="{Binding SelectedAdapter}"
                    DisplayMemberPath="DisplayText" VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="Npcap：" FontSize="11" Foreground="#78909C" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding NpcapStatusText}" FontSize="11" FontWeight="SemiBold"
                     Foreground="#1565C0" VerticalAlignment="Center"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ── 主区域：左侧配置 + 右侧工作区 ── -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="230" MinWidth="200"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ══ 左侧配置区（固定宽度，内容紧凑） ══ -->
      <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
        <DockPanel>

          <!-- 底部：执行按钮（固定在底部） -->
          <Border DockPanel.Dock="Bottom" Background="#F5F5F5" BorderBrush="#E0E0E0"
                  BorderThickness="0,1,0,0" Padding="10,8">
            <StackPanel>
              <Button Content="▶  开始发送" Command="{Binding StartCommand}"
                      Background="#2E7D32" Foreground="White" BorderThickness="0"
                      Height="34" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
              <Button Content="■  停止" Command="{Binding StopCommand}"
                      Background="#B71C1C" Foreground="White" BorderThickness="0"
                      Height="30" FontSize="12"/>
              <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"
                         FontSize="11" Foreground="#37474F" Margin="0,6,0,0"
                         HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
          </Border>

          <!-- 上方：可滚动配置内容 -->
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10,8,10,4">

              <!-- ① 选择攻击报文 -->
              <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource StepNum}">
                  <TextBlock Text="1" Foreground="White" FontSize="9" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="选择攻击报文" Style="{StaticResource SectionTitle}" Margin="0,8,0,3"/>
              </StackPanel>
              <ItemsControl ItemsSource="{Binding BuiltinPackets}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayText}"
                              Margin="0,2" FontSize="11"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="或右侧「导入报文」加载自定义报文"
                         FontSize="10" Foreground="#90A4AE" Margin="0,3,0,0" TextWrapping="Wrap"/>

              <!-- ② 设置目标 -->
              <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Border Style="{StaticResource StepNum}">
                  <TextBlock Text="2" Foreground="White" FontSize="9" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="设置目标" Style="{StaticResource SectionTitle}" Margin="0,10,0,3"/>
              </StackPanel>
              <TextBlock Text="目的 IP" Style="{StaticResource FieldLabel}"/>
              <TextBox Text="{Binding DestIp, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource CompactInput}"/>
              <TextBlock Text="{Binding DestIpError}" Foreground="#E53935" FontSize="10"/>
              <TextBlock Text="目的 MAC" Style="{StaticResource FieldLabel}"/>
              <TextBox Text="{Binding DestMac, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource CompactInput}" MaxWidth="200"/>
              <TextBlock Text="{Binding DestMacError}" Foreground="#E53935" FontSize="10"/>

              <!-- ③ 源IP递增（可选） -->
              <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Border Style="{StaticResource StepNumGray}">
                  <TextBlock Text="3" Foreground="White" FontSize="9" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <CheckBox IsChecked="{Binding SrcIpRuleEnabled}" VerticalAlignment="Center"
                          FontSize="11" FontWeight="SemiBold" Content="源IP自动递增（可选）"/>
              </StackPanel>
              <Grid IsEnabled="{Binding SrcIpRuleEnabled}" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="52"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="起始值" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding SrcIpStart, UpdateSourceTrigger=PropertyChanged}" Padding="4,3" FontSize="11" Margin="0,3,0,1"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="最大值" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding SrcIpMax, UpdateSourceTrigger=PropertyChanged}" Padding="4,3" FontSize="11" Margin="0,3,0,1"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="步长" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding SrcIpStep, UpdateSourceTrigger=PropertyChanged}" Padding="4,3" FontSize="11" Margin="0,3,0,1" MaxWidth="60" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding SrcIpRuleError}" Foreground="#E53935" FontSize="10" TextWrapping="Wrap"/>
              </Grid>

              <!-- ④ 发包配置 -->
              <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Border Style="{StaticResource StepNum}">
                  <TextBlock Text="4" Foreground="White" FontSize="9" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="发包配置" Style="{StaticResource SectionTitle}" Margin="0,10,0,3"/>
              </StackPanel>
              <!-- 速率：下拉 + 数值同行 -->
              <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="55"/>
                  <ColumnDefinition Width="26"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" SelectedIndex="{Binding SpeedModeIndex}" FontSize="11">
                  <ComboBoxItem Content="包率 (PPS)"/>
                  <ComboBoxItem Content="间隔 (μs)"/>
                  <ComboBoxItem Content="最大速率"/>
                </ComboBox>
                <TextBox Grid.Column="1" Text="{Binding SpeedValue, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{Binding SpeedValueVisible}" Margin="3,0,0,0"
                         Padding="4,3" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding SpeedValueUnit}"
                           Visibility="{Binding SpeedValueVisible}"
                           VerticalAlignment="Center" FontSize="10" Foreground="#607D8B" Margin="2,0,0,0"/>
              </Grid>
              <TextBlock Text="{Binding RateError}" Foreground="#E53935" FontSize="10"/>
              <!-- 发包模式：下拉 + 数值同行 -->
              <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="55"/>
                  <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" SelectedIndex="{Binding SendModeIndex}" FontSize="11">
                  <ComboBoxItem Content="持续发送"/>
                  <ComboBoxItem Content="定量发送"/>
                </ComboBox>
                <TextBox Grid.Column="1" Text="{Binding BurstCount, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{Binding BurstCountVisible}" Margin="3,0,0,0"
                         Padding="4,3" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="包" Visibility="{Binding BurstCountVisible}"
                           VerticalAlignment="Center" FontSize="10" Foreground="#607D8B" Margin="2,0,0,0"/>
              </Grid>
              <TextBlock Text="持续：手动停止；定量：发完自动停止"
                         FontSize="10" Foreground="#90A4AE" Margin="0,2,0,0"/>

            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- ══ 右侧工作区 ══ -->
      <DockPanel Grid.Column="1">

        <!-- 底部：统计区（固定在底部） -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#CFD8DC" BorderThickness="0,1,0,0">
          <!-- 说明条 -->
          <DockPanel>
            <Border DockPanel.Dock="Top" Background="#E3F2FD" BorderBrush="#BBDEFB"
                    BorderThickness="0,0,0,1" Padding="8,4">
              <TextBlock FontSize="10" Foreground="#1565C0">
                <Run FontWeight="Bold">实时</Run><Run> = 最近1秒；</Run>
                <Run FontWeight="Bold">平均</Run><Run> = 本次启动以来。</Run>
                <Run Foreground="#78909C">  bps = 每秒比特数（带宽）；pps = 每秒包数（速率）</Run>
              </TextBlock>
            </Border>
            <!-- 统计表格 -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="90"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="26"/>
              </Grid.RowDefinitions>
              <!-- 表头 -->
              <Border Grid.Row="0" Grid.Column="0" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"/>
              <Border Grid.Row="0" Grid.Column="1" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="实时 bps" Style="{StaticResource StatHeader}"/></Border>
              <Border Grid.Row="0" Grid.Column="2" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="实时 pps" Style="{StaticResource StatHeader}"/></Border>
              <Border Grid.Row="0" Grid.Column="3" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="平均 bps" Style="{StaticResource StatHeader}"/></Border>
              <Border Grid.Row="0" Grid.Column="4" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="平均 pps" Style="{StaticResource StatHeader}"/></Border>
              <Border Grid.Row="0" Grid.Column="5" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="报文总数" Style="{StaticResource StatHeader}"/></Border>
              <Border Grid.Row="0" Grid.Column="6" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,0,1"><TextBlock Text="总流量(B)" Style="{StaticResource StatHeader}"/></Border>
              <!-- 发送行 -->
              <Border Grid.Row="1" Grid.Column="0" Background="#F1F8E9" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1">
                <TextBlock Text="发送" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#2E7D32"/>
              </Border>
              <Border Grid.Row="1" Grid.Column="1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="{Binding Stats.CurrentBps, StringFormat=F0}" Style="{StaticResource StatBig}"/></Border>
              <Border Grid.Row="1" Grid.Column="2" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="{Binding Stats.CurrentPps, StringFormat=F1}" Style="{StaticResource StatBig}"/></Border>
              <Border Grid.Row="1" Grid.Column="3" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="{Binding Stats.AvgBps, StringFormat=F0}" Style="{StaticResource StatSmall}"/></Border>
              <Border Grid.Row="1" Grid.Column="4" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="{Binding Stats.AvgPps, StringFormat=F1}" Style="{StaticResource StatSmall}"/></Border>
              <Border Grid.Row="1" Grid.Column="5" BorderBrush="#CFD8DC" BorderThickness="0,0,1,1"><TextBlock Text="{Binding Stats.SendTotal}" Style="{StaticResource StatSmall}"/></Border>
              <Border Grid.Row="1" Grid.Column="6" BorderBrush="#CFD8DC" BorderThickness="0,0,0,1"><TextBlock Text="{Binding Stats.SendBytes}" Style="{StaticResource StatSmall}"/></Border>
              <!-- 失败行 -->
              <Border Grid.Row="2" Grid.Column="0" Background="#FFF8F8" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0">
                <TextBlock Text="失败" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="#B71C1C"/>
              </Border>
              <Border Grid.Row="2" Grid.Column="1" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0"/>
              <Border Grid.Row="2" Grid.Column="2" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0"/>
              <Border Grid.Row="2" Grid.Column="3" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0"/>
              <Border Grid.Row="2" Grid.Column="4" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0"/>
              <Border Grid.Row="2" Grid.Column="5" BorderBrush="#CFD8DC" BorderThickness="0,0,1,0">
                <TextBlock Text="{Binding Stats.SendFail}" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Padding="8,0" FontSize="12" FontWeight="SemiBold" Foreground="#C62828"/>
              </Border>
              <Border Grid.Row="2" Grid.Column="6"/>
            </Grid>
          </DockPanel>
        </Border>

        <!-- 操作按钮行 -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="8,5">
          <StackPanel Orientation="Horizontal">
            <Button Content="导入报文" Command="{Binding ImportCommand}" Padding="10,4" Margin="0,0,5,0" FontSize="11"/>
            <Button Content="编辑字段" Command="{Binding EditStreamCommand}" Padding="10,4" Margin="0,0,5,0" FontSize="11"/>
            <Button Content="删除" Command="{Binding DeleteStreamCommand}" Padding="10,4" Margin="0,0,5,0" FontSize="11"/>
            <Button Content="清空" Command="{Binding ClearStreamsCommand}" Padding="10,4" FontSize="11"
                    Background="#EF5350" Foreground="White" BorderThickness="0"/>
          </StackPanel>
        </Border>

        <!-- Stream 列表（占满剩余空间） -->
        <DataGrid ItemsSource="{Binding Streams}"
                  SelectedItem="{Binding SelectedStream}"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" FontSize="12"
                  BorderThickness="0" VerticalScrollBarVisibility="Auto">
          <DataGrid.Columns>
            <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="36"/>
            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="100"/>
            <DataGridTextColumn Header="源地址" Binding="{Binding SrcIp}" Width="105"/>
            <DataGridTextColumn Header="目的地址" Binding="{Binding DstIp}" Width="105"/>
            <DataGridTextColumn Header="协议" Binding="{Binding Type}" Width="65"/>
            <DataGridTextColumn Header="长度(B)" Binding="{Binding FrameLen}" Width="60"/>
            <DataGridTextColumn Header="信息" Binding="{Binding Info}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>

      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
