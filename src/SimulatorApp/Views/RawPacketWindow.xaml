<Window x:Class="SimulatorApp.Views.RawPacketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="攻击报文发送" Height="660" Width="960"
        MinHeight="520" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="CanResize">
  <Window.Resources>
    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#37474F"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="#607D8B"/>
      <Setter Property="Margin" Value="0,4,0,1"/>
    </Style>
    <!-- 输入框：固定宽度160，左对齐，紧凑 -->
    <Style x:Key="ShortInput" TargetType="TextBox">
      <Setter Property="Width" Value="160"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Padding" Value="5,2"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Height" Value="24"/>
    </Style>
    <!-- 下拉框：固定宽度 -->
    <Style x:Key="CompactCombo" TargetType="ComboBox">
      <Setter Property="Width" Value="120"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style x:Key="StepNum" TargetType="Border">
      <Setter Property="Background" Value="#1565C0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="Margin" Value="0,0,5,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="StepNumGray" TargetType="Border" BasedOn="{StaticResource StepNum}">
      <Setter Property="Background" Value="#90A4AE"/>
    </Style>
    <Style x:Key="StatHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Foreground" Value="#546E7A"/>
    </Style>
    <Style x:Key="StatBig" TargetType="TextBlock">
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="8,0"/>
    </Style>
    <Style x:Key="StatNormal" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="8,0"/>
      <Setter Property="Foreground" Value="#546E7A"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- 顶部工具栏 -->
      <RowDefinition Height="*"/>     <!-- 主内容 -->
    </Grid.RowDefinitions>

    <!-- ── 顶部工具栏 ── -->
    <Border Grid.Row="0" Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,0,0,1" Padding="10,6">
      <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
          <TextBlock Text="网卡" VerticalAlignment="Center" FontSize="11" Foreground="#546E7A" Margin="0,0,6,0"/>
          <ComboBox Width="320" ItemsSource="{Binding Adapters}" SelectedItem="{Binding SelectedAdapter}"
                    DisplayMemberPath="DisplayText" VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="Npcap：" FontSize="11" Foreground="#78909C" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding NpcapStatusText}" FontSize="11" FontWeight="SemiBold"
                     Foreground="#1565C0" VerticalAlignment="Center"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ── 主内容：左侧配置 + 右侧工作区 ── -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="300"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ══ 左侧配置区 ══ -->
      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>    <!-- 可滚动配置内容 -->
          <RowDefinition Height="Auto"/> <!-- 执行按钮（固定底部） -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12,8,12,4">

              <!-- ① 选择攻击报文 -->
              <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <Border Style="{StaticResource StepNum}">
                  <TextBlock Text="1" Foreground="White" FontSize="9" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="选择攻击报文" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
              </StackPanel>
              <ItemsControl ItemsSource="{Binding BuiltinPackets}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayText}" Margin="0,2" FontSize="11"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="或右侧「导入报文」加载自定义报文"
                         FontSize="10" Foreground="#90A4AE" Margin="0,3,0,0" TextWrapping="Wrap"/>

              <!-- ② 设置目标 -->
              <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                <Border Style="{StaticResource StepNum}">
                  <TextBlock Text="2" Foreground="White" FontSize="9" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="设置目标" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="目的 IP" Style="{StaticResource FieldLabel}"/>
              <TextBox Text="{Binding DestIp, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ShortInput}"/>
              <TextBlock Text="{Binding DestIpError}" Foreground="#E53935" FontSize="10"/>
              <TextBlock Text="目的 MAC" Style="{StaticResource FieldLabel}"/>
              <TextBox Text="{Binding DestMac, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ShortInput}"/>
              <TextBlock Text="{Binding DestMacError}" Foreground="#E53935" FontSize="10"/>

              <!-- ③ 源IP递增（可选） -->
              <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                <Border Style="{StaticResource StepNumGray}">
                  <TextBlock Text="3" Foreground="White" FontSize="9" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <CheckBox IsChecked="{Binding SrcIpRuleEnabled}" VerticalAlignment="Center"
                          FontSize="11" FontWeight="SemiBold" Content="源IP自动递增（可选）"/>
              </StackPanel>
              <Grid IsEnabled="{Binding SrcIpRuleEnabled}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="48"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="起始值" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding SrcIpStart, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="11" Height="22" Width="140" HorizontalAlignment="Left" Margin="0,2,0,1"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="最大值" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding SrcIpMax, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="11" Height="22" Width="140" HorizontalAlignment="Left" Margin="0,2,0,1"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="步长" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding SrcIpStep, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="11" Height="22" Margin="0,2,0,1" Width="55" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding SrcIpRuleError}" Foreground="#E53935" FontSize="10" TextWrapping="Wrap"/>
              </Grid>

              <!-- ④ 发包配置 -->
              <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                <Border Style="{StaticResource StepNum}">
                  <TextBlock Text="4" Foreground="White" FontSize="9" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="发包配置" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
              </StackPanel>
              <!-- 速率 -->
              <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <ComboBox SelectedIndex="{Binding SpeedModeIndex}" Width="120" FontSize="11">
                  <ComboBoxItem Content="包率 (PPS)"/>
                  <ComboBoxItem Content="间隔 (μs)"/>
                  <ComboBoxItem Content="最大速率"/>
                </ComboBox>
                <TextBox Text="{Binding SpeedValue, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{Binding SpeedValueVisible}" Margin="6,0,0,0"
                         Padding="4,2" FontSize="11" Width="60" Height="24" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SpeedValueUnit}" Visibility="{Binding SpeedValueVisible}"
                           VerticalAlignment="Center" FontSize="10" Foreground="#607D8B" Margin="4,0,0,0"/>
              </StackPanel>
              <TextBlock Text="{Binding RateError}" Foreground="#E53935" FontSize="10"/>
              <!-- 发包模式 -->
              <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                <ComboBox SelectedIndex="{Binding SendModeIndex}" Width="120" FontSize="11">
                  <ComboBoxItem Content="持续发送"/>
                  <ComboBoxItem Content="定量发送"/>
                </ComboBox>
                <TextBox Text="{Binding BurstCount, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{Binding BurstCountVisible}" Margin="6,0,0,0"
                         Padding="4,2" FontSize="11" Width="55" Height="24" VerticalAlignment="Center"/>
                <TextBlock Text="包" Visibility="{Binding BurstCountVisible}"
                           VerticalAlignment="Center" FontSize="10" Foreground="#607D8B" Margin="4,0,0,0"/>
              </StackPanel>
              <TextBlock Text="持续：手动停止；定量：发完自动停止"
                         FontSize="10" Foreground="#90A4AE" Margin="0,2,0,0"/>

            </StackPanel>
          </ScrollViewer>
        </Border>

        <!-- 执行按钮（固定在左侧底部） -->
        <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#E0E0E0"
                BorderThickness="0,1,1,0" Padding="12,8">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <Border Style="{StaticResource StepNum}">
                <TextBlock Text="5" Foreground="White" FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="执行" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- 按钮水平排列，自适应宽度 -->
            <StackPanel Orientation="Horizontal">
              <Button Content="▶ 开始" Command="{Binding StartCommand}"
                      Background="#2E7D32" Foreground="White" BorderThickness="0"
                      Padding="16,7" FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0"/>
              <Button Content="■ 停止" Command="{Binding StopCommand}"
                      Background="#B71C1C" Foreground="White" BorderThickness="0"
                      Padding="16,7" FontSize="12"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"
                       FontSize="11" Foreground="#37474F" Margin="0,6,0,0"
                       FontWeight="SemiBold"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ══ 右侧工作区 ══ -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>    <!-- Stream 列表（填满剩余） -->
          <RowDefinition Height="Auto"/> <!-- 操作按钮 -->
          <RowDefinition Height="Auto"/> <!-- 统计区（固定高度160） -->
        </Grid.RowDefinitions>

        <!-- Stream 列表 -->
        <Grid Grid.Row="0">
          <DataGrid ItemsSource="{Binding Streams}"
                    SelectedItem="{Binding SelectedStream}"
                    AutoGenerateColumns="False" CanUserAddRows="False"
                    IsReadOnly="True" GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column" FontSize="12"
                    BorderThickness="0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="36"/>
              <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="100"/>
              <DataGridTextColumn Header="源地址" Binding="{Binding SrcIp}" Width="105"/>
              <DataGridTextColumn Header="目的地址" Binding="{Binding DstIp}" Width="105"/>
              <DataGridTextColumn Header="协议" Binding="{Binding Type}" Width="65"/>
              <DataGridTextColumn Header="长度(B)" Binding="{Binding FrameLen}" Width="60"/>
              <DataGridTextColumn Header="信息" Binding="{Binding Info}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
          <!-- 空列表占位提示 -->
          <TextBlock Text="勾选左侧内置报文或点击「导入报文」，报文将显示在此处"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     FontSize="12" Foreground="#BDBDBD"
                     Visibility="{Binding EmptyStreamsVisibility}"/>
        </Grid>

        <!-- 操作按钮 -->
        <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,1" Padding="8,5">
          <StackPanel Orientation="Horizontal">
            <Button Content="导入报文" Command="{Binding ImportCommand}" Padding="10,4" Margin="0,0,5,0" FontSize="11"/>
            <Button Content="编辑字段" Command="{Binding EditStreamCommand}" Padding="10,4" Margin="0,0,5,0" FontSize="11"/>
            <Button Content="删除" Command="{Binding DeleteStreamCommand}" Padding="10,4" Margin="0,0,5,0" FontSize="11"/>
            <Button Content="清空" Command="{Binding ClearStreamsCommand}" Padding="10,4" FontSize="11"
                    Background="#EF5350" Foreground="White" BorderThickness="0"/>
          </StackPanel>
        </Border>

        <!-- 统计区（固定高度，紧凑卡片） -->
        <Border Grid.Row="2" Background="#F0F2F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Height="160">
          <StackPanel>
            <!-- 说明文字 -->
            <TextBlock Margin="12,5,12,5" FontSize="10" Foreground="#9E9E9E">
              <Run FontWeight="SemiBold" Foreground="#607D8B">实时</Run><Run> = 最近1秒；</Run>
              <Run FontWeight="SemiBold" Foreground="#607D8B">平均</Run><Run> = 本次启动以来。</Run>
              <Run>bps = 每秒比特数；pps = 每秒包数</Run>
            </TextBlock>

            <!-- 统计卡片：两行 3+3，固定高度 -->
            <Grid Margin="10,0,10,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="56"/>
              </Grid.RowDefinitions>

              <!-- 第一行：实时 bps / 实时 pps / 平均 bps -->
              <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="6"
                      BorderBrush="#E8E8E8" BorderThickness="1" Padding="10,6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="实时 bps" FontSize="10" Foreground="#9E9E9E" Margin="0,0,0,2"/>
                  <TextBlock Text="{Binding Stats.CurrentBps, StringFormat=F0}"
                             FontSize="18" FontWeight="Bold" Foreground="#2E7D32"/>
                </StackPanel>
              </Border>
              <Border Grid.Row="0" Grid.Column="2" Background="White" CornerRadius="6"
                      BorderBrush="#E8E8E8" BorderThickness="1" Padding="10,6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="实时 pps" FontSize="10" Foreground="#9E9E9E" Margin="0,0,0,2"/>
                  <TextBlock Text="{Binding Stats.CurrentPps, StringFormat=F1}"
                             FontSize="18" FontWeight="Bold" Foreground="#2E7D32"/>
                </StackPanel>
              </Border>
              <Border Grid.Row="0" Grid.Column="4" Background="White" CornerRadius="6"
                      BorderBrush="#E8E8E8" BorderThickness="1" Padding="10,6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="平均 bps" FontSize="10" Foreground="#9E9E9E" Margin="0,0,0,2"/>
                  <TextBlock Text="{Binding Stats.AvgBps, StringFormat=F0}"
                             FontSize="18" FontWeight="Bold" Foreground="#1565C0"/>
                </StackPanel>
              </Border>

              <!-- 第二行：平均 pps / 报文总数 / 失败数 -->
              <Border Grid.Row="2" Grid.Column="0" Background="White" CornerRadius="6"
                      BorderBrush="#E8E8E8" BorderThickness="1" Padding="10,6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="平均 pps" FontSize="10" Foreground="#9E9E9E" Margin="0,0,0,2"/>
                  <TextBlock Text="{Binding Stats.AvgPps, StringFormat=F1}"
                             FontSize="18" FontWeight="Bold" Foreground="#1565C0"/>
                </StackPanel>
              </Border>
              <Border Grid.Row="2" Grid.Column="2" Background="White" CornerRadius="6"
                      BorderBrush="#E8E8E8" BorderThickness="1" Padding="10,6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="报文总数" FontSize="10" Foreground="#9E9E9E" Margin="0,0,0,2"/>
                  <TextBlock Text="{Binding Stats.SendTotal}"
                             FontSize="18" FontWeight="Bold" Foreground="#37474F"/>
                </StackPanel>
              </Border>
              <Border Grid.Row="2" Grid.Column="4" Background="White" CornerRadius="6"
                      BorderBrush="#FFCDD2" BorderThickness="1" Padding="10,6">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="发送失败" FontSize="10" Foreground="#EF9A9A" Margin="0,0,0,2"/>
                  <TextBlock Text="{Binding Stats.SendFail}"
                             FontSize="18" FontWeight="Bold" Foreground="#C62828"/>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </Border>

      </Grid>
    </Grid>
  </Grid>
</Window>
