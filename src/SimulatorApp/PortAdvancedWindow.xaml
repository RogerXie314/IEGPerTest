<Window x:Class="SimulatorApp.PortAdvancedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="端口 &amp; EPS 诊断"
        Width="620"
        Height="560"
        MinHeight="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F6FA">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#4A90E2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderBrush" Value="#357ABD" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5BA3F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDE1EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#3A3A5C"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="110"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#222"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14,12,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left" FontSize="15" FontWeight="Bold" Foreground="#3A3A5C" VerticalAlignment="Center">端口 &amp; EPS 诊断</TextBlock>
            <TextBlock DockPanel.Dock="Right" x:Name="TxtSampleTime" FontSize="11" Foreground="#999" VerticalAlignment="Center"/>
            <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="#999" VerticalAlignment="Center" Margin="0,0,4,0">采样时刻：</TextBlock>
        </DockPanel>

        <!-- 内容区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,2,0">
            <StackPanel>

                <!-- ── 系统 TCP 配置 ── -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}">▸ 系统 TCP 配置</TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Margin="0,0,0,6">动态端口范围：</TextBlock>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtPortRange" Style="{StaticResource ValueText}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}">TIME_WAIT 超时：</TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtTimeWait" Style="{StaticResource ValueText}" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── 理论 EPS 上限 ── -->
                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource SectionTitle}" Margin="0,0,0,4">▸ 理论 EPS 上限（短连接参考）</TextBlock>
                            <TextBlock FontSize="11" Foreground="#888" Margin="0,0,0,2">⚠ 仅适用于 HTTPS 短连接模式；长连接（6000 EPS）不受此限制</TextBlock>
                            <TextBlock FontSize="11" Foreground="#666" Margin="0,4,0,2">公式：可用端口数 ÷ TIME_WAIT 时长</TextBlock>
                            <TextBlock x:Name="TxtFormula" FontSize="12" Foreground="#444" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock FontSize="11" Foreground="#666">端口利用率：</TextBlock>
                                <TextBlock x:Name="TxtCurrentUsagePct" FontSize="11" Foreground="#4A90E2" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtMultiHostTip" FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <Border x:Name="PanelMultiIp" Background="#F0F4FF" CornerRadius="4" Padding="8,5" Margin="0,6,0,0" Visibility="Collapsed">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="11" Foreground="#3949AB" FontWeight="SemiBold">多IP模式已开启：</TextBlock>
                                        <TextBlock x:Name="TxtMultiIpDesc" FontSize="11" Foreground="#3949AB"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TxtMultiIpFormula" FontSize="12" Foreground="#1A237E" FontWeight="SemiBold" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 大字 EPS -->
                        <Border Grid.Column="1" Background="#EAF1FB" CornerRadius="8" Padding="16,10" Margin="12,0,0,0" VerticalAlignment="Top">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock FontSize="10" Foreground="#666" HorizontalAlignment="Center">理论最大</TextBlock>
                                <TextBlock x:Name="TxtTheoreticalEps" FontSize="30" FontWeight="Bold" Foreground="#1565C0" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtMultiIpEps" FontSize="13" FontWeight="Bold" Foreground="#3949AB" HorizontalAlignment="Center" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── 参数优化 ── -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Height="24" FontSize="11" Padding="10,0"
                                    Background="#43A047" BorderBrush="#2E7D32"
                                    Click="BtnOneClickOptimize_Click">⚡ 一键推荐设置</Button>
                            <TextBlock Style="{StaticResource SectionTitle}" Margin="0" VerticalAlignment="Center">▸ 参数优化</TextBlock>
                        </DockPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0">端口起始：</TextBlock>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtEditPortStart" Height="22" Text="1025" VerticalContentAlignment="Center" Padding="4,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0">端口数量：</TextBlock>
                            <TextBox   Grid.Row="0" Grid.Column="4" x:Name="TxtEditPortCount" Height="22" Text="64511" VerticalContentAlignment="Center" Padding="4,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="6" FontSize="10" Foreground="#999" VerticalAlignment="Center" Margin="0,0,8,0">(最大 64511)</TextBlock>
                            <Button    Grid.Row="0" Grid.Column="8" Height="24" FontSize="11" Padding="10,0"
                                       Background="#1976D2" BorderBrush="#1565C0"
                                       Click="BtnApplyPortRange_Click">应用端口范围</Button>

                            <TextBlock Grid.Row="2" Grid.Column="0" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0">TIME_WAIT(秒)：</TextBlock>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtEditTimeWait" Height="22" Text="30" VerticalContentAlignment="Center" Padding="4,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="6" FontSize="10" Foreground="#999" VerticalAlignment="Center" Margin="0,0,8,0">(建议 30，最小 30)</TextBlock>
                            <Button    Grid.Row="2" Grid.Column="8" Height="24" FontSize="11" Padding="10,0"
                                       Background="#1976D2" BorderBrush="#1565C0"
                                       Click="BtnApplyTimeWait_Click">应用超时</Button>
                        </Grid>
                        <TextBlock x:Name="TxtOptimizeStatus" FontSize="11" Foreground="#888" TextWrapping="Wrap"
                                   Margin="0,8,0,0" Visibility="Collapsed"/>
                        <TextBlock FontSize="10" Foreground="#AAA" TextWrapping="Wrap" Margin="0,4,0,0">
                            需要管理员权限；修改端口范围立即生效，TIME_WAIT 修改重启后生效。
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Width="80" Height="30" Margin="0,0,8,0" Click="BtnRefresh_Click">刷新</Button>
            <Button Width="60" Height="30" Background="#888" BorderBrush="#666" Click="BtnClose_Click">关闭</Button>
        </StackPanel>
    </Grid>
</Window>
