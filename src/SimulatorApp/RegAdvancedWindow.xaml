<Window x:Class="SimulatorApp.RegAdvancedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="注册高级设置"
        Width="300"
        Height="200"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F6FA">
    <StackPanel Margin="16,14,16,14">
        <TextBlock FontWeight="Bold" FontSize="13" Foreground="#3A3A5C" Margin="0,0,0,12">注册高级设置</TextBlock>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="#555">并发数：</TextBlock>
            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding RegConcurrency, Mode=TwoWay}"
                       Width="120" HorizontalAlignment="Left" Margin="6,3"/>

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Foreground="#555">超时(ms)：</TextBlock>
            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding RegTimeoutMs, Mode=TwoWay}"
                       Width="120" HorizontalAlignment="Left" Margin="6,3"/>

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="#555">轮间隔(秒)：</TextBlock>
            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding RegRetryIntervalSec, Mode=TwoWay}"
                       Width="120" HorizontalAlignment="Left" Margin="6,3"/>

            <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Width="60" Height="28" HorizontalAlignment="Right" Margin="0,12,0,0"
                    Click="CloseButton_Click">确定</Button>
        </Grid>
    </StackPanel>
</Window>
