<Window x:Class="SimulatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="SimulatorApp"
    Width="1300"
    Height="820"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#4A90E2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderBrush" Value="#357ABD" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5BA3F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCC"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
            <TextBlock FontSize="18" FontWeight="Bold">模拟工具（原型）</TextBlock>
            <TextBlock Margin="12,4,0,0" Foreground="Gray">— 注册 / 心跳 / 日志 模拟</TextBlock>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="520" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="2*" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" MinWidth="220" />
                </Grid.ColumnDefinitions>

                <!-- 服务器设置 -->
                <Border Grid.Row="0" Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA" Margin="0,0,6,10">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14">服务器设置</TextBlock>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">平台 Host：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PlatformHost, Mode=TwoWay}" HorizontalAlignment="Stretch" Margin="8,2,0,2" />
                                <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0">Port：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding PlatformPort, Mode=TwoWay}" HorizontalAlignment="Stretch" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">日志 Host：</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LogHost, Mode=TwoWay}" HorizontalAlignment="Stretch" Margin="8,2,0,2" />
                                <TextBlock Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0">Port：</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding LogPort, Mode=TwoWay}" HorizontalAlignment="Stretch" Margin="8,2,0,2" />

                                <CheckBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,6,0,0" IsChecked="{Binding UseLogServer, Mode=TwoWay}"
                                          ToolTip="勾选后：心跳附加 UDP 发往日志服务器；日志发送也改为 UDP 到日志服务器（Windows/Linux 均生效）">
                                    使用日志服务器（心跳+日志均走 UDP 到日志服务器）
                                </CheckBox>

                                <Button Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Width="120" Height="30" HorizontalAlignment="Left" Margin="0,8,0,0" Command="{Binding PortTestCommand}">端口连通测试</Button>
                            </Grid>
                        </StackPanel>
                </Border>

                <!-- 客户端操作系统（跨列右侧，与服务器设置同排） -->
                <Border Grid.Row="0" Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14">客户端操作系统</TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,6">
                            <RadioButton Content="Windows" GroupName="OsType"
                                         IsChecked="{Binding IsOsWindows, Mode=TwoWay}"
                                         VerticalAlignment="Center" FontSize="13"/>
                            <RadioButton Content="Linux (CentOS 7)" GroupName="OsType"
                                         IsChecked="{Binding IsOsLinux, Mode=TwoWay}"
                                         VerticalAlignment="Center" FontSize="13" Margin="20,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding OsInfoText}" FontSize="11" Foreground="#555"
                                   TextWrapping="Wrap"/>
                        <TextBlock FontSize="10" Foreground="#999" Margin="0,4,0,0"
                                   Text="Windows → TCP 心跳；Linux → HTTPS 心跳。两种模式勾选日志服务器均会附加 UDP 心跳。切换 OS 将更新版本号下拉列表。"/>
                    </StackPanel>
                </Border>

                <!-- 左列：注册设置 / 项目类型+日志分类（占满剩余高度，不再挤压） -->
                <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,6,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14">注册设置</TextBlock>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">前缀：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RegPrefix, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">起始编号：</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RegStart, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">起始IP：</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RegStartIp, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center">数量：</TextBlock>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RegCount, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center">并发数：</TextBlock>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding RegConcurrency, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center">超时(ms)：</TextBlock>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding RegTimeoutMs, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center">轮间隔(秒)：</TextBlock>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding RegRetryIntervalSec, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center">客户端版本：</TextBlock>
                                <ComboBox Grid.Row="7" Grid.Column="1" Width="170" HorizontalAlignment="Left" Margin="8,2,0,2"
                                          ItemsSource="{Binding ClientVersionList}"
                                          SelectedItem="{Binding RegClientVersion, Mode=TwoWay}" />

                                <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Height="30" HorizontalAlignment="Left" Width="120" Margin="0,8,0,0" Command="{Binding RegisterCommand}">并发注册</Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 项目类型 + 日志分类（占满剩余全部高度，无需滚动条） -->
                    <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center">项目类型：</TextBlock>
                                <ComboBox Margin="8,0,0,0" VerticalAlignment="Center" SelectedValuePath="Content" SelectedValue="{Binding ProjectType, Mode=TwoWay}" Width="120">
                                    <ComboBoxItem Content="IEG" IsSelected="True"/>
                                    <ComboBoxItem Content="EDR"/>
                                </ComboBox>
                                <!-- 日志分类说明入口 -->
                                <Button Margin="10,0,0,0" VerticalAlignment="Center"
                                        Padding="7,3" FontSize="12" FontWeight="Normal"
                                        Background="#E8F0FE" Foreground="#1565C0"
                                        BorderBrush="#90CAF9" BorderThickness="1"
                                        Cursor="Hand"
                                        ToolTip="查看日志分类颜色说明、USB耦合关系及使用场景建议"
                                        Click="ShowLogCategoryHelp_Click">？ 分类说明</Button>
                            </StackPanel>

                            <TextBlock Grid.Row="1" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6">日志分类（勾选）</TextBlock>

                            <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Margin="8">
                                        <!-- HTTPS 短连接分类（平台规格≤100EPS） -->
                                        <TextBlock FontSize="10" Foreground="#777" Margin="0,0,0,4">HTTPS 短连接（平台规格 ≤100 EPS）</TextBlock>
                                        <WrapPanel>
                                            <CheckBox IsChecked="{Binding CatClientOps, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">客户端操作</CheckBox>
                                            <CheckBox IsChecked="{Binding CatOs, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">操作系统</CheckBox>
                                            <CheckBox IsChecked="{Binding CatOutbound, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">非法外联</CheckBox>
                                            <CheckBox IsChecked="{Binding CatFileProtect, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">文件保护</CheckBox>
                                            <CheckBox IsChecked="{Binding CatRegProtect, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">注册表保护</CheckBox>
                                            <CheckBox IsChecked="{Binding CatMandatoryAccess, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">强制访问控制</CheckBox>
                                            <CheckBox IsChecked="{Binding CatVirusAlert, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">病毒告警</CheckBox>
                                            <CheckBox IsChecked="{Binding CatUsb, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">U盘告警(老版本)</CheckBox>
                                            <CheckBox IsChecked="{Binding CatUsbWarning, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">USB访问告警</CheckBox>
                                            <CheckBox IsChecked="{Binding CatFirewall, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">防火墙</CheckBox>
                                            <CheckBox IsChecked="{Binding CatVulnProtect, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkBlue">漏洞防护(IEG)</CheckBox>
                                            <CheckBox IsChecked="{Binding CatProcessAudit, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkBlue">进程审计(IEG)</CheckBox>
                                            <CheckBox IsChecked="{Binding CatNonWhitelist, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkBlue">非白名单(IEG)</CheckBox>
                                            <CheckBox IsChecked="{Binding CatWhitelistTamper, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkBlue">白名单防篡改(IEG)</CheckBox>
                                            <CheckBox IsChecked="{Binding CatSysGuard, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkGreen">系统防护(EDR)</CheckBox>
                                        </WrapPanel>
                                        <!-- 插拔 & 网口事件分组 -->
                                        <Border BorderBrush="#7BB0D0" BorderThickness="1" CornerRadius="3" Margin="0,4,0,0" Padding="6,4">
                                            <StackPanel>
                                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#1A5070" Margin="0,0,0,4">插拔 &amp; 网口事件（IEG）</TextBlock>
                                                <WrapPanel>
                                                    <CheckBox IsChecked="{Binding CatUDiskPlug, Mode=TwoWay}" Margin="0,0,16,4" MinWidth="100">U盘插拔</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatNetAdapterEvent, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="120" Foreground="DarkBlue">网口Up/Down</CheckBox>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <!-- 外设控制分组 -->
                                        <Border BorderBrush="#B0C4DE" BorderThickness="1" CornerRadius="3" Margin="0,4,0,0" Padding="6,4">
                                            <StackPanel>
                                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#4A6080" Margin="0,0,0,4">外设控制（IEG）— 禁用触发告警</TextBlock>
                                                <WrapPanel>
                                                    <CheckBox IsChecked="{Binding CatExtDevUsbPort, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁USB接口</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevWpd, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁手机平板</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevCdrom, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁CDROM</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevWlan, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁无线网卡</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevUsbEthernet, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁USB网卡</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevFloppy, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁软盘</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevBluetooth, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁蓝牙</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevSerial, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁串口</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevParallel, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁并口</CheckBox>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <!-- 威胁检测分组（TCP长连接，平台规格6000EPS） -->
                                        <Border BorderBrush="#C8A020" BorderThickness="1" CornerRadius="3" Margin="0,6,0,0" Padding="6,4" Background="#FFFDF0">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False" Margin="0,0,0,4">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#7A5800">威胁检测（5种事件）— TCP长连接，平台规格6000EPS</TextBlock>
                                                </DockPanel>
                                                <WrapPanel>
                                                    <CheckBox IsChecked="{Binding CatThreatProcStart, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="110" Foreground="DarkGreen">进程启动(EDR)</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatThreatRegAccess, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="120" Foreground="DarkGreen">注册表访问事件(EDR)</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatThreatFileAccess, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="110" Foreground="DarkGreen">文件访问(EDR)</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatThreatDllLoad, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="110" Foreground="DarkGreen">DLL加载(EDR)</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatThreatOsEvent, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="120" Foreground="DarkBlue">操作系统日志(IEG)</CheckBox>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 右列：心跳设置 / 白名单上传设置 / 日志发送设置 -->
                <DockPanel Grid.Row="1" Grid.Column="1" Margin="6,0,0,0" LastChildFill="True">

                    <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold" FontSize="14">心跳设置</TextBlock>
                                <Border Background="#E3F2FD" CornerRadius="3" Padding="5,1" Margin="8,1,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding HeartbeatModeLabel}" Foreground="#1565C0" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">间隔 (ms)：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding HbInterval, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">策略接收：</TextBlock>
                                <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding EnablePolicyReceive, Mode=TwoWay}"
                                          VerticalAlignment="Center" Margin="8,3,0,3"
                                          ToolTip="开启后心跳连接中的策略下发将被解析并自动回包（仅 TCP/Windows 模式生效）" />

                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Width="75" Height="28" Command="{Binding StartHeartbeatCommand}">开始心跳</Button>
                                    <Button Grid.Column="2" Width="50" Height="28" Command="{Binding StopHeartbeatCommand}">停止</Button>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14">程序白名单上传设置</TextBlock>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">文件：</TextBlock>
                                <TextBox Grid.Column="1" Text="{Binding WhitelistFilePath, Mode=TwoWay}" IsReadOnly="True" Margin="8,2,8,2" />
                                <Button Grid.Column="2" Width="90" Height="28" Margin="0,2,0,2" Command="{Binding BrowseWhitelistFileCommand}">选择文件</Button>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">客户端数：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WhitelistClientCount, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">并发度：</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WhitelistConcurrency, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">轮间隔(秒)：</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WhitelistCycleIntervalSec, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2"
                                         ToolTip="每轮随机上传后等待的秒数（默认900=15分钟）" />

                                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Width="75" Height="28" Command="{Binding StartWhitelistUploadCommand}">添加任务</Button>
                                    <Button Grid.Column="2" Width="75" Height="28" Command="{Binding StopWhitelistUploadCommand}">结束任务</Button>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,0">
                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center">
                                    日志发送设置
                                </TextBlock>
                                <Button DockPanel.Dock="Right" Width="100" Height="20"
                                        FontSize="11" Foreground="White" Padding="4,0"
                                        Background="#7986CB" BorderBrush="#5C6BC0"
                                        Click="ShowTcpDiag_Click">📊 连接参数诊断</Button>
                            </DockPanel>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="70" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" MinWidth="32" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 共享：每客户端总条数 -->
                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">每客户端总条数：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding LogMessagesPerClient, Mode=TwoWay}" Width="80" HorizontalAlignment="Left" Margin="6,2,0,2" />

                                <!-- HTTPS 短连接通道 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6"
                                           FontWeight="SemiBold" FontSize="12" Foreground="#1976D2" Margin="0,10,0,3">
                                    HTTPS 短连接<Run FontSize="11" FontWeight="Normal" Foreground="#888">（≤100 EPS）</Run>
                                </TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">客户端数：</TextBlock>
                                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding LogHttpsClientCount, Mode=TwoWay}" Width="60" HorizontalAlignment="Left" Margin="6,2,0,2" />
                                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0">每秒：</TextBlock>
                                <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding LogHttpsEps, Mode=TwoWay}" Width="50" HorizontalAlignment="Left" Margin="4,2,0,2" />
                                <TextBlock Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Foreground="#666" FontSize="11" Margin="4,0,0,0">条</TextBlock>

                                <!-- 威胁检测 TCP 长连接通道 -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6"
                                           FontWeight="SemiBold" FontSize="12" Foreground="#B8860B" Margin="0,10,0,3">
                                    威胁检测 TCP 长连接<Run FontSize="11" FontWeight="Normal" Foreground="#888">（6000 EPS）</Run>
                                </TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center">客户端数：</TextBlock>
                                <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding LogThreatClientCount, Mode=TwoWay}" Width="60" HorizontalAlignment="Left" Margin="6,2,0,2" />
                                <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0">每秒：</TextBlock>
                                <TextBox   Grid.Row="4" Grid.Column="3" Text="{Binding LogThreatEps, Mode=TwoWay}" Width="50" HorizontalAlignment="Left" Margin="4,2,0,2" />
                                <TextBlock Grid.Row="4" Grid.Column="4" VerticalAlignment="Center" Foreground="#666" FontSize="11" Margin="4,0,0,0">轮/秒</TextBlock>

                                <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="6" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Width="75" Height="28" Command="{Binding StartLogSendCommand}">添加任务</Button>
                                    <Button Grid.Column="2" Width="75" Height="28" Command="{Binding StopLogSendCommand}">结束任务</Button>
                                </Grid>

                                <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="6" Margin="0,6,0,0"
                                           Foreground="Gray" FontSize="11"
                                           Text="威胁检测：每轮依次发送全部勾选类型（对齐C++ SendThreatLog），轮/秒=EPS/N种" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="200" MinHeight="100" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="*" MinHeight="80" />
                </Grid.RowDefinitions>

                <!-- 任务与状态：2×2 网格，节省纵向空间 -->
                <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FFF" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8">任务与状态</TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 注册统计 -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock FontWeight="Bold">注册统计</TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Width="80">目标客户端：</TextBlock>
                                    <TextBlock Text="{Binding RegTotal}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="80">成功/失败：</TextBlock>
                                    <TextBlock Text="{Binding RegSuccess}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding RegFailed}" Foreground="Red" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="80">已完成轮次：</TextBlock>
                                    <TextBlock Text="{Binding RegRound}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="80" VerticalAlignment="Top">失败原因：</TextBlock>
                                    <TextBlock Text="{Binding RegFailureDetail}" TextWrapping="Wrap" Foreground="DarkOrange" MaxWidth="140" />
                                </StackPanel>
                            </StackPanel>

                            <!-- 心跳统计 -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock FontWeight="Bold">心跳统计</TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Width="90">目标客户端：</TextBlock>
                                    <TextBlock Text="{Binding HbTotal}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90" ToolTip="TCP模式=当前持有TCP连接的客户端数；HTTPS模式=本轮HTTP响应成功数">在线客户端：</TextBlock>
                                    <TextBlock Text="{Binding HbConnected}" Foreground="DodgerBlue" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90" ToolTip="WriteAsync 未抛异常。数据已进入 OS TCP 发送缓冲区，不代表平台已处理。">已发送/失败：</TextBlock>
                                    <TextBlock Text="{Binding HbTcpOk}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding HbTcpFail}" Foreground="Red" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90" FontWeight="SemiBold" ToolTip="平台有回包：服务端对本次连接返回过数据。这是最接近「平台真实在线」的客户端侧指标。" Foreground="#E67E00">▶ 平台回包：</TextBlock>
                                    <TextBlock Text="{Binding HbServerReplied}" Foreground="#E67E00" FontWeight="SemiBold" />
                                    <TextBlock Text=" / " Margin="2,0" Foreground="Gray"/>
                                    <TextBlock Text="{Binding HbTotal}" Foreground="Gray" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90">UDP 成功/失败：</TextBlock>
                                    <TextBlock Text="{Binding HbUdpOk}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding HbUdpFail}" Foreground="Red" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Width="90" FontWeight="SemiBold" Foreground="#7B68EE">策略收到/回包：</TextBlock>
                                    <TextBlock Text="{Binding PolicyReceived}" Foreground="#7B68EE" />
                                    <TextBlock Text=" / " Margin="2,0" Foreground="Gray"/>
                                    <TextBlock Text="{Binding PolicyReplied}" Foreground="MediumPurple" />
                                </StackPanel>
                            </StackPanel>

                            <!-- 日志发送统计 -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock FontWeight="Bold">日志发送统计</TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Width="80">总消息：</TextBlock>
                                    <TextBlock Text="{Binding LogTotalMessages}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="80">成功/失败：</TextBlock>
                                    <TextBlock Text="{Binding LogSuccess}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding LogFailed}" Foreground="Red" />
                                </StackPanel>
                            </StackPanel>

                            <!-- 白名单上传统计 -->
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock FontWeight="Bold">白名单上传统计</TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Width="90">目标客户端：</TextBlock>
                                    <TextBlock Text="{Binding UploadTotal}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90">成功/失败：</TextBlock>
                                    <TextBlock Text="{Binding UploadSuccess}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding UploadFailed}" Foreground="Red" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 任务面板 DataGrid -->
                <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="8" Background="#F7F7FF" Margin="0,0,0,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4">任务面板</TextBlock>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding TaskRecords}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  RowHeight="24"
                                  FontSize="12"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"         Binding="{Binding Id}"          Width="36" />
                                <DataGridTextColumn Header="任务类型"   Binding="{Binding TaskType}"     Width="80" />
                                <DataGridTextColumn Header="开始时间"   Binding="{Binding StartTime, StringFormat=HH:mm:ss}" Width="70" />
                                <DataGridTextColumn Header="客户端数"   Binding="{Binding ClientCount}"  Width="68" />
                                <DataGridTextColumn Header="间隔"       Binding="{Binding IntervalText}" Width="56" />
                                <DataGridTextColumn Header="状态"       Binding="{Binding StatusText}"   Width="56">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding StatusColor}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="成功"       Binding="{Binding SuccessCount}" Width="48" />
                                <DataGridTextColumn Header="失败"       Binding="{Binding FailCount}"    Width="48" />
                                <DataGridTextColumn Header="耗时"       Binding="{Binding DurationText}" Width="60" />
                                <DataGridTextColumn Header="详情"       Binding="{Binding Detail}"       Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- 任务面板与日志区分隔线（可拖动调整高度） -->
                <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" Background="#D0D0D0"
                              ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True" />

                <!-- 日志区域 -->
                <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FFF" Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" FontWeight="Bold" Margin="0,0,0,8">日志</TextBlock>
                        <TextBox Grid.Row="1" Text="{Binding StatusLog, Mode=OneWay}"
                                 VerticalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True"
                                 Background="Transparent" BorderThickness="0" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>