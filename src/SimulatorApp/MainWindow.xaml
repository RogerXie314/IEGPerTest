<Window x:Class="SimulatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimulatorApp" Height="350" Width="600">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock FontSize="16" FontWeight="Bold">模拟工具（原型）</TextBlock>
            <TextBlock Margin="0,8,0,0">基础控制：可在此触发注册与心跳（演示）。</TextBlock>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <GroupBox Header="服务器设置" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Width="80">平台 Host：</TextBlock>
                                <TextBox x:Name="TxtPlatformHost" Width="160" />
                                <TextBlock Width="60" Margin="8,0,0,0">Port：</TextBlock>
                                <TextBox x:Name="TxtPlatformPort" Width="80" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Width="80">日志 Host：</TextBlock>
                                <TextBox x:Name="TxtLogHost" Width="160" />
                                <TextBlock Width="60" Margin="8,0,0,0">Port：</TextBlock>
                                <TextBox x:Name="TxtLogPort" Width="80" />
                            </StackPanel>
                            <Button x:Name="BtnPortTest" Width="120" Height="28" Margin="0,8,0,0" Click="BtnPortTest_Click">端口连通测试</Button>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="注册设置" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="80">前缀：</TextBlock>
                                <TextBox Text="{Binding RegPrefix, Mode=TwoWay}" Width="160" />
                                <TextBlock Width="60" Margin="8,0,0,0">起始：</TextBlock>
                                <TextBox Text="{Binding RegStart, Mode=TwoWay}" Width="80" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Width="80">数量：</TextBlock>
                                <TextBox Text="{Binding RegCount, Mode=TwoWay}" Width="80" />
                                <Button Width="120" Height="28" Margin="12,0,0,0" Command="{Binding RegisterCommand}">并发注册</Button>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="心跳设置" Padding="8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="80">间隔(ms)：</TextBlock>
                                <TextBox Text="{Binding HbInterval, Mode=TwoWay}" Width="80" />
                                <Button Width="120" Height="28" Margin="12,0,0,0" Command="{Binding StartHeartbeatCommand}">开始心跳</Button>
                                <Button Width="120" Height="28" Margin="8,0,0,0" Command="{Binding StopHeartbeatCommand}">停止心跳</Button>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock FontWeight="Bold">任务与状态</TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,6">
                        <Button Width="100" Command="{Binding RefreshClientsCommand}">刷新 Clients</Button>
                        <Button Width="100" Margin="8,0,0,0" Command="{Binding ExportClientsCommand}">导出 Clients</Button>
                        <Button Width="100" Margin="8,0,0,0" Command="{Binding ImportClientsCommand}">导入 Clients</Button>
                        <Button Width="100" Margin="8,0,0,0" Command="{Binding ClearClientsCommand}">清理 Clients</Button>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Clients}" AutoGenerateColumns="False" Margin="0,4,0,0" Height="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ClientId" Binding="{Binding ClientId}" Width="*" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IP}" Width="120" />
                            <DataGridTextColumn Header="RegisteredAt" Binding="{Binding RegisteredAt}" Width="200" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>

                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>