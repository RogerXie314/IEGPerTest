<Window x:Class="SimulatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="SimulatorApp"
    Width="1300"
    Height="820"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#4A90E2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderBrush" Value="#357ABD" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5BA3F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCC"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
            <TextBlock FontSize="18" FontWeight="Bold">模拟工具（原型）</TextBlock>
            <TextBlock Margin="12,4,0,0" Foreground="Gray">— 注册 / 心跳 / 日志 模拟</TextBlock>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="520" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="2*" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" MinWidth="220" />
                </Grid.ColumnDefinitions>

                <!-- 服务器设置（跨两列） -->
                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14">服务器设置</TextBlock>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">平台 Host：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PlatformHost, Mode=TwoWay}" HorizontalAlignment="Stretch" Margin="8,2,0,2" />
                                <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0">Port：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding PlatformPort, Mode=TwoWay}" HorizontalAlignment="Stretch" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">日志 Host：</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LogHost, Mode=TwoWay}" HorizontalAlignment="Stretch" Margin="8,2,0,2" />
                                <TextBlock Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0">Port：</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding LogPort, Mode=TwoWay}" HorizontalAlignment="Stretch" Margin="8,2,0,2" />

                                <CheckBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,6,0,0" IsChecked="{Binding UseLogServer, Mode=TwoWay}">
                                    使用日志服务器（心跳 UDP / 其他日志 UDP）
                                </CheckBox>

                                <Button Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Width="120" Height="30" HorizontalAlignment="Left" Margin="0,8,0,0" Command="{Binding PortTestCommand}">端口连通测试</Button>

                                <Grid Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="2" Margin="8,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Width="90" Height="30" Command="{Binding StartHttpsHeartbeatCommand}" Margin="0,0,4,0">HTTPS 心跳</Button>
                                    <Button Grid.Column="1" Width="60" Height="30" Command="{Binding StopHttpsHeartbeatCommand}">停止</Button>
                                </Grid>
                            </Grid>
                        </StackPanel>
                </Border>

                <!-- 左列：注册设置 / 项目类型+日志分类（占满剩余高度，不再挤压） -->
                <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,6,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14">注册设置</TextBlock>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">前缀：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RegPrefix, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">起始编号：</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RegStart, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">起始IP：</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RegStartIp, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center">数量：</TextBlock>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RegCount, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center">并发数：</TextBlock>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding RegConcurrency, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center">超时(ms)：</TextBlock>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding RegTimeoutMs, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center">轮间隔(秒)：</TextBlock>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding RegRetryIntervalSec, Mode=TwoWay}" Width="150" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Height="30" HorizontalAlignment="Left" Width="120" Margin="0,8,0,0" Command="{Binding RegisterCommand}">并发注册</Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 项目类型 + 日志分类（占满剩余全部高度，无需滚动条） -->
                    <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center">项目类型：</TextBlock>
                                <ComboBox Margin="8,0,0,0" VerticalAlignment="Center" SelectedValuePath="Content" SelectedValue="{Binding ProjectType, Mode=TwoWay}" Width="120">
                                    <ComboBoxItem Content="IEG" IsSelected="True"/>
                                    <ComboBoxItem Content="EDR"/>
                                </ComboBox>
                            </StackPanel>

                            <TextBlock Grid.Row="1" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6">日志分类（勾选）</TextBlock>

                            <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Margin="8">
                                        <!-- 通用分类 -->
                                        <WrapPanel>
                                            <CheckBox IsChecked="{Binding CatClientOps, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">客户端操作</CheckBox>
                                            <CheckBox IsChecked="{Binding CatOs, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">操作系统</CheckBox>
                                            <CheckBox IsChecked="{Binding CatOutbound, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">非法外联</CheckBox>
                                            <CheckBox IsChecked="{Binding CatThreat, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">威胁数据采集</CheckBox>
                                            <CheckBox IsChecked="{Binding CatFileProtect, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">文件保护</CheckBox>
                                            <CheckBox IsChecked="{Binding CatRegProtect, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">注册表保护</CheckBox>
                                            <CheckBox IsChecked="{Binding CatMandatoryAccess, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">强制访问控制</CheckBox>
                                            <CheckBox IsChecked="{Binding CatVirusAlert, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">病毒告警</CheckBox>
                                            <CheckBox IsChecked="{Binding CatUsb, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">USB设备</CheckBox>
                                            <CheckBox IsChecked="{Binding CatUsbWarning, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">USB访问告警</CheckBox>
                                            <CheckBox IsChecked="{Binding CatUDiskPlug, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">U盘插拔</CheckBox>
                                            <CheckBox IsChecked="{Binding CatFirewall, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100">防火墙</CheckBox>
                                            <CheckBox IsChecked="{Binding CatVulnProtect, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkBlue">漏洞防护(IEG)</CheckBox>
                                            <CheckBox IsChecked="{Binding CatProcessAudit, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkBlue">进程审计(IEG)</CheckBox>
                                            <CheckBox IsChecked="{Binding CatNonWhitelist, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkBlue">非白名单(IEG)</CheckBox>
                                            <CheckBox IsChecked="{Binding CatWhitelistTamper, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkBlue">白名单防篡改(IEG)</CheckBox>
                                            <CheckBox IsChecked="{Binding CatSysGuard, Mode=TwoWay}" Margin="0,0,12,6" MinWidth="100" Foreground="DarkGreen">系统防护(EDR)</CheckBox>
                                        </WrapPanel>
                                        <!-- 外设控制分组 -->
                                        <Border BorderBrush="#B0C4DE" BorderThickness="1" CornerRadius="3" Margin="0,6,0,0" Padding="6,4">
                                            <StackPanel>
                                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#4A6080" Margin="0,0,0,4">外设控制（IEG）— 禁用触发告警</TextBlock>
                                                <WrapPanel>
                                                    <CheckBox IsChecked="{Binding CatExtDevUsbPort, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁USB接口</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevWpd, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁手机平板</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevCdrom, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁CDROM</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevWlan, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁无线网卡</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevUsbEthernet, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁USB网卡</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevFloppy, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁软盘</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevBluetooth, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁蓝牙</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevSerial, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁串口</CheckBox>
                                                    <CheckBox IsChecked="{Binding CatExtDevParallel, Mode=TwoWay}" Margin="0,0,12,4" MinWidth="90" Foreground="DarkBlue">禁并口</CheckBox>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 右列：心跳设置 / 白名单上传设置 / 日志发送设置 -->
                <DockPanel Grid.Row="1" Grid.Column="1" Margin="6,0,0,0" LastChildFill="True">
                    <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14">心跳设置</TextBlock>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">间隔 (ms)：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding HbInterval, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Width="75" Height="28" Command="{Binding StartHeartbeatCommand}">开始心跳</Button>
                                    <Button Grid.Column="2" Width="50" Height="28" Command="{Binding StopHeartbeatCommand}">停止</Button>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14">程序白名单上传设置</TextBlock>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">文件：</TextBlock>
                                <TextBox Grid.Column="1" Text="{Binding WhitelistFilePath, Mode=TwoWay}" IsReadOnly="True" Margin="8,2,8,2" />
                                <Button Grid.Column="2" Width="90" Height="28" Margin="0,2,0,2" Command="{Binding BrowseWhitelistFileCommand}">选择文件</Button>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">客户端数：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WhitelistClientCount, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">并发度：</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WhitelistConcurrency, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Width="75" Height="28" Command="{Binding StartWhitelistUploadCommand}">添加任务</Button>
                                    <Button Grid.Column="2" Width="75" Height="28" Command="{Binding StopWhitelistUploadCommand}">结束任务</Button>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FAFAFA">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,0">
                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center">
                                    日志发送设置
                                    <Run FontSize="11" FontWeight="Normal" Foreground="#888">（默认短连接）</Run>
                                </TextBlock>
                                <Button DockPanel.Dock="Right" Width="100" Height="20"
                                        FontSize="11" Foreground="White" Padding="4,0"
                                        Background="#7986CB" BorderBrush="#5C6BC0"
                                        Click="ShowTcpDiag_Click">📊 连接参数诊断</Button>
                            </DockPanel>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">客户端个数：</TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LogClientCount, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">每客户端总条数：</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LogMessagesPerClient, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">每客户端每秒条数：</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LogMessagesPerSecondPerClient, Mode=TwoWay}" Width="90" HorizontalAlignment="Left" Margin="8,2,0,2" />

                                <!-- 并发连接数（压测模式下生效） -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLogStressMode}" Value="False">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock VerticalAlignment="Center">并发连接数：</TextBlock>
                                    <Border Background="#1976D2" CornerRadius="8" Width="16" Height="16"
                                            VerticalAlignment="Center" Margin="4,0,0,0" Cursor="Help">
                                        <TextBlock Text="i" Foreground="White" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.ToolTip>
                                                <ToolTip>
                                                    <StackPanel MaxWidth="320">
                                                        <TextBlock FontWeight="Bold" Margin="0,0,0,4">压测模式：并发连接数</TextBlock>
                                                        <TextBlock TextWrapping="Wrap">压测模式下同时向平台保持的最大 HTTPS 连接数，同时也是信号量门控容量。</TextBlock>
                                                        <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" FontWeight="SemiBold">最大 EPS = 并发数 × (1000 / 平均响应ms)</TextBlock>
                                                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" Foreground="#555">示例（局域网 20ms 响应）：</TextBlock>
                                                        <TextBlock Margin="8,2,0,0" Foreground="#555">50 并发 → 2500 EPS</TextBlock>
                                                        <TextBlock Margin="8,2,0,0" Foreground="#555">200 并发 → 10000 EPS</TextBlock>
                                                        <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" Foreground="Gray" FontStyle="Italic">仅在压测模式下生效，模拟模式忽略此项。</TextBlock>
                                                    </StackPanel>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <TextBox Grid.Row="3" Grid.Column="1"
                                         Text="{Binding LogConcurrency, Mode=TwoWay}"
                                         Width="90" HorizontalAlignment="Left" Margin="8,2,0,2"
                                         IsEnabled="{Binding IsLogStressMode}" />

                                <!-- 压测模式开关 -->
                                <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                          Margin="0,6,0,0" IsChecked="{Binding IsLogStressMode, Mode=TwoWay}">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="340">
                                                <TextBlock FontWeight="Bold" Margin="0,0,0,4">日志发送模式对比</TextBlock>
                                                <TextBlock FontWeight="SemiBold">■ 模拟模式（默认，不勾选）</TextBlock>
                                                <TextBlock TextWrapping="Wrap" Margin="8,2,0,4" Foreground="#333">每条日志新建独立 TLS 连接，完全对齐原始客户端行为。端口每条消耗1个（120s后释放），单机约 50 客户端上限（~100 EPS）。用途：验证行为兼容性。</TextBlock>
                                                <TextBlock FontWeight="SemiBold">■ 压测模式（勾选）</TextBlock>
                                                <TextBlock TextWrapping="Wrap" Margin="8,2,0,4" Foreground="#333">连接复用 + 信号量门控，消除端口耗尽。单机可模拟 3000 客户端 / 6000+ EPS。平台感知不到连接方式差异（HTTP 请求内容完全相同）。用途：测试平台吞吐上限。</TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center">压测模式<Run FontSize="11" Foreground="#888">（连接池复用）</Run></TextBlock>
                                        <Border Background="#1976D2" CornerRadius="8" Width="16" Height="16"
                                                VerticalAlignment="Center" Margin="5,0,0,0" Cursor="Help">
                                            <TextBlock Text="i" Foreground="White" FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </CheckBox>

                                <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Width="75" Height="28" Command="{Binding StartLogSendCommand}">添加任务</Button>
                                    <Button Grid.Column="2" Width="75" Height="28" Command="{Binding StopLogSendCommand}">结束任务</Button>
                                </Grid>

                                <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,0" Foreground="Gray" Text="(按 Clients.log 前 N 个客户端)" />

                                <!-- 多IP模式开关 -->
                                <CheckBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                          Margin="0,10,0,0" IsChecked="{Binding IsLogMultiIpMode, Mode=TwoWay}">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="340">
                                                <TextBlock FontWeight="Bold" Margin="0,0,0,4">多IP模式</TextBlock>
                                                <TextBlock TextWrapping="Wrap" Foreground="#333">给网卡绑定多个本地 IP 后，每个 IP 拥有独立的端口池。短连接时轮转绑定各 IP，理论 EPS = N 个 IP × 单IP上限。</TextBlock>
                                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" FontWeight="SemiBold">示例：3 个 IP = 3 × 546 ≈ 1638 EPS</TextBlock>
                                                <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" Foreground="#555">配置方法：Windows → 网络设置 → TCP/IPv4 属性 → 高级 → 添加多个 IP 地址。</TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center">多IP模式（短连接EPS扩容）</TextBlock>
                                        <Border Background="#1976D2" CornerRadius="8" Width="16" Height="16"
                                                VerticalAlignment="Center" Margin="5,0,0,0" Cursor="Help">
                                            <TextBlock Text="i" Foreground="White" FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </CheckBox>

                                <!-- 本地 IP 列表输入 -->
                                <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,2">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLogMultiIpMode}" Value="False">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <DockPanel LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,4,0">IP 列表：</TextBlock>
                                        <TextBox Text="{Binding LogLocalIps, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding IsLogMultiIpMode}"
                                                 HorizontalAlignment="Stretch" />
                                    </DockPanel>
                                    <TextBlock FontSize="10" Foreground="#999" Margin="0,2,0,0" TextWrapping="Wrap" MaxWidth="280">逗号分隔，如：192.168.1.10,192.168.1.11</TextBlock>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 任务与状态：2×2 网格，节省纵向空间 -->
                <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FFF" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8">任务与状态</TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 注册统计 -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock FontWeight="Bold">注册统计</TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Width="80">目标客户端：</TextBlock>
                                    <TextBlock Text="{Binding RegTotal}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="80">成功/失败：</TextBlock>
                                    <TextBlock Text="{Binding RegSuccess}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding RegFailed}" Foreground="Red" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="80">已完成轮次：</TextBlock>
                                    <TextBlock Text="{Binding RegRound}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="80" VerticalAlignment="Top">失败原因：</TextBlock>
                                    <TextBlock Text="{Binding RegFailureDetail}" TextWrapping="Wrap" Foreground="DarkOrange" MaxWidth="140" />
                                </StackPanel>
                            </StackPanel>

                            <!-- 心跳统计 -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock FontWeight="Bold">心跳统计</TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Width="90">目标客户端：</TextBlock>
                                    <TextBlock Text="{Binding HbTotal}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90">TCP 已连接：</TextBlock>
                                    <TextBlock Text="{Binding HbConnected}" Foreground="DodgerBlue" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90" ToolTip="WriteAsync 未抛异常。数据已进入 OS TCP 发送缓冲区，不代表平台已处理。">已发送/失败：</TextBlock>
                                    <TextBlock Text="{Binding HbTcpOk}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding HbTcpFail}" Foreground="Red" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90" FontWeight="SemiBold" ToolTip="平台有回包：服务端对本次连接返回过数据。这是最接近「平台真实在线」的客户端侧指标。" Foreground="#E67E00">▶ 平台回包：</TextBlock>
                                    <TextBlock Text="{Binding HbServerReplied}" Foreground="#E67E00" FontWeight="SemiBold" />
                                    <TextBlock Text=" / " Margin="2,0" Foreground="Gray"/>
                                    <TextBlock Text="{Binding HbTotal}" Foreground="Gray" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90">UDP 成功/失败：</TextBlock>
                                    <TextBlock Text="{Binding HbUdpOk}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding HbUdpFail}" Foreground="Red" />
                                </StackPanel>
                            </StackPanel>

                            <!-- 日志发送统计 -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock FontWeight="Bold">日志发送统计</TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Width="80">总消息：</TextBlock>
                                    <TextBlock Text="{Binding LogTotalMessages}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="80">成功/失败：</TextBlock>
                                    <TextBlock Text="{Binding LogSuccess}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding LogFailed}" Foreground="Red" />
                                </StackPanel>
                            </StackPanel>

                            <!-- 白名单上传统计 -->
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock FontWeight="Bold">白名单上传统计</TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Width="90">目标客户端：</TextBlock>
                                    <TextBlock Text="{Binding UploadTotal}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Width="90">成功/失败：</TextBlock>
                                    <TextBlock Text="{Binding UploadSuccess}" Foreground="Green" />
                                    <TextBlock Text=" / " Margin="2,0" />
                                    <TextBlock Text="{Binding UploadFailed}" Foreground="Red" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 日志区域 -->
                <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FFF" Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" FontWeight="Bold" Margin="0,0,0,8">日志</TextBlock>
                        <TextBox Grid.Row="1" Text="{Binding StatusLog, Mode=OneWay}"
                                 VerticalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True"
                                 Background="Transparent" BorderThickness="0" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>