<Window x:Class="SimulatorApp.SshLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📦 SSH 日志收集进度"
        Width="720" Height="520"
        MinWidth="480" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True"
        Closing="Window_Closing">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 日志内容区（ReadOnly TextBox，支持选中/复制） -->
        <TextBox Grid.Row="0"
                 x:Name="TxtLog"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 Background="#1E1E1E"
                 Foreground="#CCCCCC"
                 FontFamily="Consolas"
                 FontSize="12"
                 Padding="8,6"
                 BorderThickness="1"
                 BorderBrush="#444"
                 CaretBrush="Transparent"
                 SelectionBrush="#4A90E2"/>

        <!-- 底部按钮行 -->
        <DockPanel Grid.Row="2">
            <TextBlock x:Name="TxtStatus" DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       FontSize="11" Foreground="#666"
                       Text="等待收集…"/>
            <Button DockPanel.Dock="Right" Width="70" Height="28"
                    Margin="8,0,0,0" Background="#546E7A" BorderBrush="#37474F"
                    Click="BtnClose_Click">关闭</Button>
            <Button DockPanel.Dock="Right" Width="70" Height="28"
                    Background="#795548" BorderBrush="#5D4037"
                    Click="BtnClear_Click">清除</Button>
            <Button DockPanel.Dock="Right" Width="100" Height="28"
                    Margin="0,0,8,0" Background="#37474F" BorderBrush="#263238"
                    x:Name="BtnOpenDir" Visibility="Collapsed"
                    Click="BtnOpenDir_Click">📂 打开目录</Button>
        </DockPanel>
    </Grid>
</Window>
