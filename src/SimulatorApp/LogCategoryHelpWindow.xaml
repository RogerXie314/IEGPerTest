<Window x:Class="SimulatorApp.LogCategoryHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="日志分类 — 使用说明"
        Width="640"
        Height="660"
        MinWidth="520"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F6FA">

    <Window.Resources>
        <!-- 卡片容器 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <!-- 卡片标题 -->
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
        <!-- 正文 -->
        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>
        <!-- 色块标签 -->
        <Style x:Key="ColorDot" TargetType="Border">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <!-- 关闭按钮 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#357ABD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#357ABD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- 顶部标题 -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#222">日志分类模块说明</TextBlock>
            <TextBlock FontSize="12" Foreground="#777" Margin="0,4,0,0">
                帮助您正确勾选合适的日志类型，以匹配目标服务端的压测场景
            </TextBlock>
        </StackPanel>

        <!-- 底部关闭按钮 -->
        <Button DockPanel.Dock="Bottom" HorizontalAlignment="Right"
                Margin="0,10,0,0" Click="CloseButton_Click">关 闭</Button>

        <!-- 正文内容（滚动） -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- ① 项目类型 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitle}">① 项目类型（IEG / EDR）</TextBlock>
                        <TextBlock Style="{StaticResource Body}">
                            切换"项目类型"决定模拟器向服务端上报哪个产品线的日志格式。<LineBreak/>
                            <LineBreak/>
                            • <Run FontWeight="SemiBold">IEG</Run>：传统安全管控产品，使用 HTTPS 短连接，平台压测规格 ≤ 100 EPS。<LineBreak/>
                            • <Run FontWeight="SemiBold">EDR</Run>：端点检测与响应产品，威胁检测类日志使用 TCP 长连接，平台规格最高 6000 EPS。<LineBreak/>
                            <LineBreak/>
                            <Run Foreground="#C0392B">注意：切换项目类型不会自动取消勾选，请手动确认勾选项与项目类型匹配。</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ② 颜色含义 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitle}">② 字体颜色含义</TextBlock>
                        <!-- 黑色 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource ColorDot}" Background="#333"/>
                            <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#333">黑色（默认）</TextBlock>
                        </StackPanel>
                        <TextBlock Style="{StaticResource Body}" Margin="18,0,0,10">
                            IEG 和 EDR 均支持的通用日志类型，两种项目类型下均可勾选使用。<LineBreak/>
                            示例：客户端操作、操作系统、非法外联、防火墙、病毒告警、U盘告警(老版本)…
                        </TextBlock>
                        <!-- 蓝色 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource ColorDot}" Background="DarkBlue"/>
                            <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="DarkBlue">蓝色 (DarkBlue)</TextBlock>
                        </StackPanel>
                        <TextBlock Style="{StaticResource Body}" Margin="18,0,0,10">
                            <Run FontWeight="SemiBold">IEG 专属</Run>日志类型，仅在"项目类型 = IEG"时选用。<LineBreak/>
                            示例：漏洞防护(IEG)、进程审计(IEG)、非白名单(IEG)、白名单防篡改(IEG)、<LineBreak/>
                            外设控制 9 种禁用子类（禁USB接口 / 禁手机平板 / 禁CDROM 等）、操作系统日志(IEG)、<Run FontWeight="SemiBold">网口Up/Down(IEG)</Run>。
                        </TextBlock>
                        <!-- 绿色 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource ColorDot}" Background="DarkGreen"/>
                            <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="DarkGreen">绿色 (DarkGreen)</TextBlock>
                        </StackPanel>
                        <TextBlock Style="{StaticResource Body}" Margin="18,0,0,0">
                            <Run FontWeight="SemiBold">EDR 专属</Run>日志类型，仅在"项目类型 = EDR"时选用。<LineBreak/>
                            示例：系统防护(EDR)、进程启动(EDR)、注册表访问事件(EDR)、文件访问(EDR)、DLL加载(EDR)。
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ③ USB相关分类 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitle}">③ USB / 网口：插拔相关分类说明</TextBlock>

                        <!-- 表格式说明 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- 表头 -->
                            <Border Grid.Row="0" Grid.Column="0" Background="#F0F4F8" Padding="6,4">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#555">分类名称</TextBlock>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Background="#F0F4F8" Padding="6,4">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#555">说明</TextBlock>
                            </Border>
                            <!-- U盘告警(老版本) -->
                            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,1,1,0" Padding="6,6">
                                <TextBlock FontSize="12" FontWeight="SemiBold">U盘告警(老版本)</TextBlock>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="6,6">
                                <TextBlock Style="{StaticResource Body}">
                                    旧版通用 U 盘禁用告警（UsbType=2，LogContent="U盘使用被禁止"），模拟旧版 IEG 客户端上报行为。当前版本 IEG 源码产生的外设告警 UsbType 从 4 开始（外设控制9种子类），不再产生 UsbType=2，仅用于验证服务端向后兼容性。
                                </TextBlock>
                            </Border>
                            <!-- 外设控制 -->
                            <Border Grid.Row="2" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,1,1,0" Padding="6,6" Background="#EEF3FF">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="DarkBlue">外设控制（9种）</TextBlock>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="6,6" Background="#EEF3FF">
                                <TextBlock Style="{StaticResource Body}">
                                    IEG 新版精细化告警，每种外设有专属 UsbType 值（CDROM=4, 蓝牙=6, 串口=7…），<Run FontWeight="SemiBold">服务端可精确区分被禁设备种类</Run>。与"U盘告警(老版本)"共用同一接口 /USM/clientULog.do，但 UsbType 字段不同。<LineBreak/>
                                    <Run Foreground="#1565C0" FontStyle="Italic">推荐：测试 IEG 外设策略时，优先勾选此区域的具体子类，不必再勾"U盘告警(老版本)"。</Run>
                                </TextBlock>
                            </Border>
                            <!-- USB访问告警 -->
                            <Border Grid.Row="3" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,1,1,0" Padding="6,6">
                                <TextBlock FontSize="12" FontWeight="SemiBold">USB访问告警</TextBlock>
                            </Border>
                            <Border Grid.Row="3" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="6,6">
                                <TextBlock Style="{StaticResource Body}">
                                    U盘<Run FontWeight="SemiBold">插入后</Run>，对文件进行<Run FontWeight="SemiBold">违规操作</Run>（非法读写）时产生。接口：/USM/clientUSBLog.do。
                                </TextBlock>
                            </Border>
                            <!-- U盘插拔 -->
                            <Border Grid.Row="4" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,1,1,0" Padding="6,6">
                                <TextBlock FontSize="12" FontWeight="SemiBold">U盘插拔</TextBlock>
                            </Border>
                            <Border Grid.Row="4" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="6,6">
                                <TextBlock Style="{StaticResource Body}">
                                    U盘<Run FontWeight="SemiBold">物理插入/拔出动作本身</Run>的上报，V3R2 新增。接口：/USM/hotplugDevLog.do。<LineBreak/>
                                    <Run FontWeight="SemiBold">共用 CMDID=204，CMDVER=1</Run>，数据在 CMDContent 数组中。
                                </TextBlock>
                            </Border>
                            <!-- 网口Up/Down -->
                            <Border Grid.Row="5" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,1,1,1" Padding="6,6" Background="#EEF3FF">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="DarkBlue">网口Up/Down</TextBlock>
                            </Border>
                            <Border Grid.Row="5" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,1" Padding="6,6" Background="#EEF3FF">
                                <TextBlock Style="{StaticResource Body}">
                                    网卡接口 Up/Down 状态变化事件。接口：/USM/hotplugDevLog.do，<LineBreak/>
                                    <Run FontWeight="SemiBold">共用 CMDID=204，CMDVER=4</Run>，数据在 CMDContentOtherDev 中，OtherDevType=7。<LineBreak/>
                                    PlugEvent 字段：2=UP变化触发，4=DOWN变化触发，1/3=状态轮询。<LineBreak/>
                                    <Run Foreground="#1565C0" FontStyle="Italic">IEG 专属，对应 IEG 源码 WLCUDisk/WLNetAdapterEvent.cpp。</Run>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ④ 典型场景选择建议 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitle}">④ 典型压测场景选择建议</TextBlock>

                        <TextBlock Style="{StaticResource Body}" FontWeight="SemiBold" Margin="0,0,0,4">场景 A：IEG 综合压测（HTTPS 短连接压力）</TextBlock>
                        <TextBlock Style="{StaticResource Body}" Margin="10,0,0,8">
                            项目类型选 IEG，勾选黑色 + 蓝色分类。外设控制选具体子类（如禁USB接口 + 禁蓝牙），无需再勾"U盘告警(老版本)"。
                        </TextBlock>

                        <TextBlock Style="{StaticResource Body}" FontWeight="SemiBold" Margin="0,0,0,4">场景 B：EDR 威胁检测压测（TCP 长连接高频）</TextBlock>
                        <TextBlock Style="{StaticResource Body}" Margin="10,0,0,8">
                            项目类型选 EDR，勾选威胁检测区域的绿色分类（进程启动 / 文件访问 / DLL加载等）。TCP 长连接模式，平台规格最高 6000 EPS。
                        </TextBlock>

                        <TextBlock Style="{StaticResource Body}" FontWeight="SemiBold" Margin="0,0,0,4">场景 C：U盘管控全链路验证</TextBlock>
                        <TextBlock Style="{StaticResource Body}" Margin="10,0,0,8">
                            同时勾选"U盘插拔"（模拟插入动作） + "USB访问告警"（模拟违规文件操作），验证服务端两条接口处理能力。
                        </TextBlock>

                        <TextBlock Style="{StaticResource Body}" FontWeight="SemiBold" Margin="0,0,0,4">场景 D：测试老版本 IEG 兼容性</TextBlock>
                        <TextBlock Style="{StaticResource Body}" Margin="10,0,0,8">
                            勾选"U盘告警(老版本)"（通用 UsbType=2），模拟旧版客户端上报行为，验证服务端向后兼容性。
                        </TextBlock>

                        <TextBlock Style="{StaticResource Body}" FontWeight="SemiBold" Margin="0,0,0,4">场景 E：网口管控 / 网络准入验证</TextBlock>
                        <TextBlock Style="{StaticResource Body}" Margin="10,0,0,0">
                            勾选"网口Up/Down"，模拟终端网卡接口上下线事件上报（CMDVER=4，OtherDevType=7），验证服务端对网口状态变化的处理与审计能力。可与"U盘插拔"同时勾选，共同压测 /USM/hotplugDevLog.do 接口。
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
