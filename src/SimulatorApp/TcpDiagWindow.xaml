<Window x:Class="SimulatorApp.TcpDiagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="连接参数诊断"
        Width="660"
        Height="680"
        MinHeight="400"
        MaxHeight="880"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F6FA">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#4A90E2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderBrush" Value="#357ABD" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5BA3F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDE1EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#3A3A5C"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="110"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#222"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14,12,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 标题栏 ── -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="Bold" Foreground="#3A3A5C" VerticalAlignment="Center">连接参数诊断</TextBlock>
            <TextBlock DockPanel.Dock="Right" x:Name="TxtSampleTime" FontSize="11" Foreground="#999" VerticalAlignment="Center" Margin="0,0,0,0"/>
            <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="#999" VerticalAlignment="Center" Margin="0,0,4,0">采样时刻：</TextBlock>
            <Button DockPanel.Dock="Right" Height="24" FontSize="11" Padding="10,0" Margin="0,0,12,0"
                    Background="#7B5EA7" BorderBrush="#5C3D8F"
                    Click="BtnPortAdvanced_Click">🔧 端口 &amp; EPS</Button>
        </DockPanel>

        <!-- ── 内容区（可滚动）── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,2,0">
            <StackPanel>

        <!-- ── 当前连接状态 ── -->
        <Border Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}">▸ 当前连接状态</TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ESTABLISHED -->
                    <Border Grid.Column="0" Background="#EAF6EA" CornerRadius="5" Padding="10,8" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="ESTABLISHED" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtEstablished" FontSize="22" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- TIME_WAIT -->
                    <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="5" Padding="10,8" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="TIME_WAIT" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtTimeWaitCount" FontSize="22" FontWeight="Bold" Foreground="#E65100" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 其他状态 -->
                    <Border Grid.Column="2" Background="#F3F3F3" CornerRadius="5" Padding="10,8" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="其他状态" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtOtherCount" FontSize="22" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 端口占用 -->
                    <Border Grid.Column="3" Background="#EEF2FF" CornerRadius="5" Padding="10,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="端口占用" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPortsUsed" FontSize="13" FontWeight="Bold" Foreground="#3949AB" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 端口占用进度条 -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="TxtPortUsageBar" Grid.Column="0" Height="10" Minimum="0" Maximum="100" Foreground="#4A90E2" Background="#E0E0E0"/>
                    <TextBlock x:Name="TxtPortUsageLabel" Grid.Column="1" Margin="8,0,0,0" FontSize="11" Foreground="#555" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── 心跳 / 日志连接参数 ── -->
        <Border x:Name="ConnParamsPanel" Style="{StaticResource SectionBorder}" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}">▸ 心跳 / 日志连接参数</TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 心跳 TCP -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Margin="0,0,0,5">心跳 TCP：</TextBlock>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock x:Name="TxtHbTarget" Style="{StaticResource ValueText}" Margin="0,0,14,0"/>
                        <TextBlock Text="已连接 " Foreground="#666" VerticalAlignment="Center" FontSize="11"/>
                        <TextBlock x:Name="TxtHbConnected" FontWeight="SemiBold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 端口来源说明 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}">端口来源：</TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtHbPortNote" FontSize="11" Foreground="#888" TextWrapping="Wrap"/>

                    <!-- 日志 TCP -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Margin="0,0,0,4">日志 TCP：</TextBlock>
                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock x:Name="TxtLogTcpMode" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock Text="  →  " FontSize="11" Foreground="#AAA" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtLogTcpTarget" Style="{StaticResource ValueText}"/>
                    </StackPanel>

                    <!-- 日志 HTTPS -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}">日志 HTTPS：</TextBlock>
                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="短连接  →  " FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtLogHttpsTarget" Style="{StaticResource ValueText}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── 平台日志收集 (SSH) ── -->
        <Border Style="{StaticResource SectionBorder}">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource SectionTitle}" Margin="0" VerticalAlignment="Center">▸ 平台日志收集 (SSH) </TextBlock>
                    <TextBlock FontSize="11" Foreground="#999" VerticalAlignment="Center">自动将平台 /root/logs + 本地调试日志集中到一个目录</TextBlock>
                </DockPanel>

                <!-- SSH 参数行 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row0: Host / Port / LogPath -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Width="Auto" Margin="0,0,4,0">平台主机：</TextBlock>
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtSshHost" Height="22" VerticalContentAlignment="Center" Padding="4,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource LabelText}" Width="Auto" Margin="0,0,4,0">端口：</TextBlock>
                    <TextBox   Grid.Row="0" Grid.Column="4" x:Name="TxtSshPort" Height="22" Text="22" VerticalContentAlignment="Center" Padding="4,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="6" Style="{StaticResource LabelText}" Width="Auto" Margin="0,0,4,0">日志目录：</TextBlock>
                    <TextBox   Grid.Row="0" Grid.Column="7" x:Name="TxtSshLogPath" Height="22" Text="/root/logs" VerticalContentAlignment="Center" Padding="4,0"/>

                    <!-- Row2: 用户名 / 密码 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Width="Auto" Margin="0,0,4,0">用户名：</TextBlock>
                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtSshUser" Height="22" Text="sysadmin" VerticalContentAlignment="Center" Padding="4,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Style="{StaticResource LabelText}" Width="Auto" Margin="0,0,4,0">密码：</TextBlock>
                    <PasswordBox Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="4" x:Name="PbSshPassword" Height="22" VerticalContentAlignment="Center" Padding="4,0"/>

                    <!-- Row4: 大文件阈值 / 时间偏差 -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}" Width="Auto" Margin="0,0,4,0">大文件阈值(MB)：</TextBlock>
                    <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtSshThreshold" Height="22" Text="50" VerticalContentAlignment="Center" Padding="4,0" Width="50" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="4" Grid.Column="3" Style="{StaticResource LabelText}" Width="Auto" Margin="0,0,4,0">时间偏差：</TextBlock>
                    <TextBlock Grid.Row="4" Grid.Column="4" Grid.ColumnSpan="4" x:Name="TxtTimeSkew" FontSize="11" FontWeight="SemiBold" Foreground="#888" VerticalAlignment="Center">（连接后检测）</TextBlock>

                    <!-- Row6: 采集时间段 -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource LabelText}" Width="Auto" Margin="0,0,4,0">采集时间段：</TextBlock>
                    <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="7" Orientation="Horizontal">
                        <TextBox x:Name="TxtSshTimeFrom" Height="22" Width="135" VerticalContentAlignment="Center" Padding="4,0">
                            <TextBox.ToolTip>格式：yyyy-MM-dd HH:mm</TextBox.ToolTip>
                        </TextBox>
                        <TextBlock VerticalAlignment="Center" Margin="6,0" FontSize="13">～</TextBlock>
                        <TextBox x:Name="TxtSshTimeTo"   Height="22" Width="135" VerticalContentAlignment="Center" Padding="4,0">
                            <TextBox.ToolTip>格式：yyyy-MM-dd HH:mm</TextBox.ToolTip>
                        </TextBox>
                    </StackPanel>
                </Grid>

                <!-- 按鈕行 -->
                <DockPanel Margin="0,4,0,6">
                    <Button DockPanel.Dock="Left" x:Name="BtnCollectLogs" Height="28" Padding="14,0"
                            Background="#00897B" BorderBrush="#00695C"
                            Click="BtnCollectLogs_Click">📦 开始收集日志</Button>
                    <Button DockPanel.Dock="Left" x:Name="BtnOpenOutputDir" Height="28" Padding="10,0"
                            Background="#546E7A" BorderBrush="#37474F"
                            Margin="8,0,0,0" Visibility="Collapsed"
                            Click="BtnOpenOutputDir_Click">📂 打开输出目录</Button>
                    <TextBlock x:Name="TxtSshProgress" DockPanel.Dock="Left"
                               Margin="12,0,0,0" VerticalAlignment="Center"
                               FontSize="11" Foreground="#666"/>
                </DockPanel>

                <TextBlock FontSize="10" Foreground="#AAA" Margin="0,2,0,0">密码明文保存在 config.json，仅供内网开发调试使用。</TextBlock>
            </StackPanel>
        </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── 底部按鈕 ── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Width="80" Height="30" Margin="0,0,8,0" Click="BtnRefresh_Click">刷新</Button>
            <Button Width="60" Height="30" Background="#888" BorderBrush="#666" Click="BtnClose_Click">关闭</Button>
        </StackPanel>

    </Grid>
</Window>
