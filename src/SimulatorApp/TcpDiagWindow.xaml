<Window x:Class="SimulatorApp.TcpDiagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="连接参数诊断"
        Width="660"
        SizeToContent="Height"
        MinHeight="300"
        MaxHeight="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F6FA">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#4A90E2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderBrush" Value="#357ABD" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5BA3F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDE1EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#3A3A5C"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="110"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#222"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14,12,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 标题栏 ── -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="Bold" Foreground="#3A3A5C" VerticalAlignment="Center">连接参数诊断</TextBlock>
            <TextBlock DockPanel.Dock="Right" x:Name="TxtSampleTime" FontSize="11" Foreground="#999" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,0,0"/>
            <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="#999" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0">采样时刻：</TextBlock>
        </DockPanel>

        <!-- ── 系统 TCP 配置 ── -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}">▸ 系统 TCP 配置</TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Margin="0,0,0,6">动态端口范围：</TextBlock>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtPortRange" Style="{StaticResource ValueText}" Margin="0,0,0,6" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}">TIME_WAIT 超时：</TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtTimeWait" Style="{StaticResource ValueText}" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── 当前连接状态 ── -->
        <Border Grid.Row="2" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}">▸ 当前连接状态</TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ESTABLISHED -->
                    <Border Grid.Column="0" Background="#EAF6EA" CornerRadius="5" Padding="10,8" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="ESTABLISHED" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtEstablished" FontSize="22" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- TIME_WAIT -->
                    <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="5" Padding="10,8" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="TIME_WAIT" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtTimeWaitCount" FontSize="22" FontWeight="Bold" Foreground="#E65100" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 其他状态 -->
                    <Border Grid.Column="2" Background="#F3F3F3" CornerRadius="5" Padding="10,8" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="其他状态" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtOtherCount" FontSize="22" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 端口占用 -->
                    <Border Grid.Column="3" Background="#EEF2FF" CornerRadius="5" Padding="10,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="端口占用" FontSize="10" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPortsUsed" FontSize="13" FontWeight="Bold" Foreground="#3949AB" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 端口占用进度条 -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="TxtPortUsageBar" Grid.Column="0" Height="10" Minimum="0" Maximum="100" Foreground="#4A90E2" Background="#E0E0E0"/>
                    <TextBlock x:Name="TxtPortUsageLabel" Grid.Column="1" Margin="8,0,0,0" FontSize="11" Foreground="#555" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── 心跳 / 日志连接参数 ── -->
        <Border x:Name="ConnParamsPanel" Grid.Row="3" Style="{StaticResource SectionBorder}" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}">▸ 心跳 / 日志连接参数</TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 心跳 TCP -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelText}" Margin="0,0,0,5">心跳 TCP：</TextBlock>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock x:Name="TxtHbTarget" Style="{StaticResource ValueText}" Margin="0,0,14,0"/>
                        <TextBlock Text="已连接 " Foreground="#666" VerticalAlignment="Center" FontSize="11"/>
                        <TextBlock x:Name="TxtHbConnected" FontWeight="SemiBold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 端口来源说明 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}">端口来源：</TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtHbPortNote" FontSize="11" Foreground="#888" TextWrapping="Wrap"/>

                    <!-- 日志 TCP -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Margin="0,0,0,4">日志 TCP：</TextBlock>
                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock x:Name="TxtLogTcpMode" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock Text="  →  " FontSize="11" Foreground="#AAA" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtLogTcpTarget" Style="{StaticResource ValueText}"/>
                    </StackPanel>

                    <!-- 日志 HTTPS -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}">日志 HTTPS：</TextBlock>
                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="短连接  →  " FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtLogHttpsTarget" Style="{StaticResource ValueText}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── 理论 EPS 估算 ── -->
        <Border Grid.Row="4" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SectionTitle}" Margin="0,0,0,4">▸ 理论 EPS 上限</TextBlock>
                    <TextBlock FontSize="11" Foreground="#666" Margin="0,0,0,2">公式：可用端口数 ÷ TIME_WAIT 时长</TextBlock>
                    <TextBlock x:Name="TxtFormula" FontSize="12" Foreground="#444" Margin="0,0,0,4" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock FontSize="11" Foreground="#666">端口利用率：</TextBlock>
                        <TextBlock x:Name="TxtCurrentUsagePct" FontSize="11" Foreground="#4A90E2" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtMultiHostTip" FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    <!-- 多IP模式额外行 -->
                    <Border x:Name="PanelMultiIp" Background="#F0F4FF" CornerRadius="4" Padding="8,5" Margin="0,6,0,0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="11" Foreground="#3949AB" FontWeight="SemiBold">多IP模式已开启：</TextBlock>
                                <TextBlock x:Name="TxtMultiIpDesc" FontSize="11" Foreground="#3949AB"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtMultiIpFormula" FontSize="12" Foreground="#1A237E" FontWeight="SemiBold" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 大字 EPS 数字 -->
                <Border Grid.Column="1" Background="#EAF1FB" CornerRadius="8" Padding="16,10" Margin="12,0,0,0" VerticalAlignment="Top">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock FontSize="10" Foreground="#666" HorizontalAlignment="Center">理论最大</TextBlock>
                        <TextBlock x:Name="TxtTheoreticalEps" FontSize="32" FontWeight="Bold" Foreground="#1565C0" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtMultiIpEps" FontSize="14" FontWeight="Bold" Foreground="#3949AB" HorizontalAlignment="Center" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── 参数优化 ── -->
        <Border Grid.Row="5" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right" Height="24" FontSize="11" Padding="10,0"
                            Background="#43A047" BorderBrush="#2E7D32"
                            Click="BtnOneClickOptimize_Click">⚡ 一键推荐设置</Button>
                    <TextBlock Style="{StaticResource SectionTitle}" Margin="0" VerticalAlignment="Center">▸ 参数优化</TextBlock>
                </DockPanel>

                <!-- 端口范围 + TIME_WAIT 统一 Grid，标签列 Auto，永不截断 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 行0：动态端口范围 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0">端口起始：</TextBlock>
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtEditPortStart" Height="22" Text="1025" VerticalContentAlignment="Center" Padding="4,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0">端口数量：</TextBlock>
                    <TextBox   Grid.Row="0" Grid.Column="4" x:Name="TxtEditPortCount" Height="22" Text="64511" VerticalContentAlignment="Center" Padding="4,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="6" FontSize="10" Foreground="#999" VerticalAlignment="Center" Margin="0,0,8,0">(最大 64511)</TextBlock>
                    <Button    Grid.Row="0" Grid.Column="8" Height="24" FontSize="11" Padding="10,0"
                               Background="#1976D2" BorderBrush="#1565C0"
                               Click="BtnApplyPortRange_Click">应用端口范围</Button>

                    <!-- 行2：TIME_WAIT -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0">TIME_WAIT(秒)：</TextBlock>
                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtEditTimeWait" Height="22" Text="30" VerticalContentAlignment="Center" Padding="4,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="6" FontSize="10" Foreground="#999" VerticalAlignment="Center" Margin="0,0,8,0">(建议 30，最小 30)</TextBlock>
                    <Button    Grid.Row="2" Grid.Column="8" Height="24" FontSize="11" Padding="10,0"
                               Background="#1976D2" BorderBrush="#1565C0"
                               Click="BtnApplyTimeWait_Click">应用超时</Button>
                </Grid>

                <TextBlock x:Name="TxtOptimizeStatus" FontSize="11" Foreground="#888" TextWrapping="Wrap"
                           Margin="0,8,0,0" Visibility="Collapsed"/>
                <TextBlock FontSize="10" Foreground="#AAA" TextWrapping="Wrap" Margin="0,4,0,0">
                    需要管理员权限；修改端口范围立即生效，TIME_WAIT 修改重启后生效。
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 底部按钮 ── -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Width="80" Height="30" Margin="0,0,8,0" Click="BtnRefresh_Click">刷新</Button>
            <Button Width="60" Height="30" Background="#888" BorderBrush="#666" Click="BtnClose_Click">关闭</Button>
        </StackPanel>

    </Grid>
</Window>
