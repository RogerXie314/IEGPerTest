<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <OutputType>WinExe</OutputType>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <Version>3.8.4</Version>
    <AssemblyVersion>3.8.4.0</AssemblyVersion>
    <FileVersion>3.8.4.0</FileVersion>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\\SimulatorLib\\SimulatorLib.csproj" />
  </ItemGroup>
  <!-- йҚҳзҶәж•“ C++ DLLй”ӣж°¬еҺӣйҗў?publish й‘ҙж°ӯж№°зјӮж ¬зҳ§й”ӣеұҪе•Җйҗў?dotnet publish йҺөж’№з№ҳйҚ—жӣҹжһғжө ?EXE -->
  <ItemGroup>
    <None Include="..\..\src\NativeEngine\build\Release\NativeEngine.dll" Condition="Exists('..\..\src\NativeEngine\build\Release\NativeEngine.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
      <ExcludeFromSingleFile>false</ExcludeFromSingleFile>
      <Link>NativeEngine.dll</Link>
    </None>
    <None Include="..\..\src\NativeSender\build\Release\NativeSender.dll" Condition="Exists('..\..\src\NativeSender\build\Release\NativeSender.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
      <ExcludeFromSingleFile>false</ExcludeFromSingleFile>
      <Link>NativeSender.dll</Link>
    </None>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="SSH.NET" Version="2024.2.0" />
  </ItemGroup>
</Project>