<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <OutputType>WinExe</OutputType>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <Version>3.8.5</Version>
    <AssemblyVersion>3.8.5.0</AssemblyVersion>
    <FileVersion>3.8.5.0</FileVersion>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\\SimulatorLib\\SimulatorLib.csproj" />
  </ItemGroup>
  <!-- й–ёжЁје–“йҸҒ?C++ DLLй–ҝж¶ҷиүҫйҚҳж¶ўжӮҪ?publish й–јеӯҳзўҚе©Җжү®зҙ“йҸҚо„Ӯж§Ҝй–ҝж¶ҳиӢҜйҚҹвӮ¬й–»?dotnet publish й–№еһ«жҚҒз»»ж©ҖеҙЎйҸҮзҶёзҖ®еЁҙ?EXE -->
  <ItemGroup>
    <None Include="..\..\src\NativeEngine\build\Release\NativeEngine.dll" Condition="Exists('..\..\src\NativeEngine\build\Release\NativeEngine.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
      <ExcludeFromSingleFile>false</ExcludeFromSingleFile>
      <Link>NativeEngine.dll</Link>
    </None>
    <None Include="..\..\src\NativeSender\build\Release\NativeSender.dll" Condition="Exists('..\..\src\NativeSender\build\Release\NativeSender.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
      <ExcludeFromSingleFile>false</ExcludeFromSingleFile>
      <Link>NativeSender.dll</Link>
    </None>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="SSH.NET" Version="2024.2.0" />
  </ItemGroup>
</Project>